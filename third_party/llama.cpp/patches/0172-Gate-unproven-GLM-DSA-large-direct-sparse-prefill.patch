From ecdb6627caaf164dfeff7333c6d1369d771cff11 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 03:43:36 +1000
Subject: [PATCH] Gate unproven GLM DSA large direct sparse prefill

---
 src/llama-graph.cpp | 9 ++++++++-
 src/skippy.cpp      | 7 ++++++-
 2 files changed, 14 insertions(+), 2 deletions(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 12219c894..f8c49e7c7 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -61,10 +61,14 @@ static bool skippy_glm_dsa_direct_sparse_prefill_enabled() {
     return true;
 }
 
+static bool skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled() {
+    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL");
+}
+
 static int64_t skippy_glm_dsa_direct_sparse_prefill_max_tokens() {
     const char * value = getenv("SKIPPY_GLM_DSA_DIRECT_SPARSE_PREFILL_MAX_TOKENS");
     if (value == nullptr || value[0] == '\0') {
-        return 32;
+        return 8;
     }
 
     const int64_t parsed = atoll(value);
@@ -156,6 +160,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
         int64_t dense_mask_limit,
         bool    direct_sparse_enabled,
         bool    direct_sparse_prefill_enabled,
+        bool    unproven_large_direct_sparse_prefill_enabled,
         bool    flash_attn,
         bool    compact_flash_disabled,
         bool    kq_b_ok,
@@ -181,6 +186,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
             sparse_batch <= prefill_cap;
     policy.large_prefill_shape =
             direct_sparse_prefill_enabled &&
+            unproven_large_direct_sparse_prefill_enabled &&
             sparse_batch > prefill_cap &&
             dense_mask_bytes > dense_mask_limit;
     policy.token_shape_allowed =
@@ -3189,6 +3195,7 @@ ggml_tensor * llm_graph_context::build_attn(
             dense_sparse_mask_limit,
             direct_sparse_enabled,
             direct_sparse_prefill_enabled,
+            skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled(),
             cparams.flash_attn,
             skippy_glm_dsa_compact_flash_attn_disabled(),
             direct_sparse_kq_b_ok,
diff --git a/src/skippy.cpp b/src/skippy.cpp
index 333742122..0d4010559 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1632,8 +1632,12 @@ static bool skippy_glm_dsa_direct_sparse_prefill_enabled() {
     return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_PREFILL");
 }
 
+static bool skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled() {
+    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL");
+}
+
 static uint32_t skippy_glm_dsa_direct_sparse_prefill_max_tokens() {
-    return skippy_env_u32("SKIPPY_GLM_DSA_DIRECT_SPARSE_PREFILL_MAX_TOKENS", 32, 1, 4096);
+    return skippy_env_u32("SKIPPY_GLM_DSA_DIRECT_SPARSE_PREFILL_MAX_TOKENS", 8, 1, 4096);
 }
 
 static uint64_t skippy_glm_dsa_dense_sparse_mask_max_bytes() {
@@ -1856,6 +1860,7 @@ static void skippy_glm_dsa_log_direct_sparse_decision_for_tensor(
             sparse_batch <= static_cast<int64_t>(prefill_cap);
     const bool large_prefill_shape =
             prefill_enabled &&
+            skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled() &&
             sparse_batch > static_cast<int64_t>(prefill_cap) &&
             dense_mask_bytes > dense_mask_limit;
     const bool token_shape_allowed = decode_shape || prefill_shape || large_prefill_shape;
-- 
2.53.0

