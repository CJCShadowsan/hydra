From 28fce4dec870b85fe31b2580c6ab7cef4980e206 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 10:08:02 +1000
Subject: [PATCH 228/228] Prefer GLM DSA compact flash decode by default

---
 src/llama-graph.cpp        |  4 ++--
 tests/test-backend-ops.cpp | 16 ++++++++++++----
 tests/test-llama-archs.cpp | 10 +++++-----
 3 files changed, 19 insertions(+), 11 deletions(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 6bba48b4a..ffb5afc62 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -139,7 +139,7 @@ static int64_t skippy_glm_dsa_compact_flash_min_kv() {
         if (filter.glm_dsa_policy_profile != 0 && filter.glm_dsa_compact_flash_min_kv > 0) {
             return filter.glm_dsa_compact_flash_min_kv;
         }
-        return 256;
+        return 1;
     }
 
     const int64_t parsed = atoll(value);
@@ -272,7 +272,7 @@ struct llama_glm_dsa_sparse_attn_policy {
     }
 };
 
-static constexpr int64_t LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K = 256;
+static constexpr int64_t LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K = 0;
 
 static int64_t skippy_glm_dsa_direct_sparse_decode_max_top_k() {
     const char * value = getenv("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K");
diff --git a/tests/test-backend-ops.cpp b/tests/test-backend-ops.cpp
index 1061252d0..9f3ccf9a7 100644
--- a/tests/test-backend-ops.cpp
+++ b/tests/test-backend-ops.cpp
@@ -10432,10 +10432,18 @@ static std::vector<std::unique_ptr<test_case>> make_test_cases_perf() {
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q2_K, GGML_TYPE_F32, 256, 8, false, 2048, 1, 6144));
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q3_K, GGML_TYPE_F32, 256, 8, false, 6144, 1, 2048));
 
-    // GLM-DSA sparse-attention phase shapes.
-    test_cases.emplace_back(new test_glm_dsa_selected_row_flash(257, 64));
-    test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, 257, 1, 1, 1, 64, 1));
-    test_cases.emplace_back(new test_flash_attn_ext(576, 512, 1, {1, 1}, 257, 1, true, false, 0, 0, GGML_PREC_F32, GGML_TYPE_F16, GGML_TYPE_F16));
+    // GLM-DSA sparse-attention decode threshold shapes.
+    for (int64_t kv : {128, 256, 257, 513}) {
+        test_cases.emplace_back(new test_glm_dsa_selected_row_flash(kv, 64));
+        test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, kv, 1, 1, 1, 64, 1));
+        test_cases.emplace_back(new test_flash_attn_ext(576, 512, 1, {1, 1}, kv, 1, true, false, 0, 0, GGML_PREC_F32, GGML_TYPE_F16, GGML_TYPE_F16));
+    }
+    for (int64_t kv : {128, 256, 257, 513}) {
+        test_cases.emplace_back(new test_glm_dsa_selected_row_flash(kv, kv));
+        test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, kv, 1, 1, 1, kv, 1));
+    }
+
+    // GLM-DSA sparse-attention short phase shapes.
     test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, 257, 4, 1, 1, 64, 1));
     test_cases.emplace_back(new test_flash_attn_ext(576, 512, 1, {1, 1}, 257, 4, true, false, 0, 0, GGML_PREC_F32, GGML_TYPE_F16, GGML_TYPE_F16));
     test_cases.emplace_back(new test_dsa_sparse_attn(GGML_TYPE_F32, GGML_TYPE_F32, GGML_TYPE_F32, 576, 512, 257, 8, 1, 1, 64, 1));
diff --git a/tests/test-llama-archs.cpp b/tests/test-llama-archs.cpp
index 4e022109a..6a0e06c24 100644
--- a/tests/test-llama-archs.cpp
+++ b/tests/test-llama-archs.cpp
@@ -634,6 +634,7 @@ static glm_dsa_graph_op_counts run_glm_dsa_prefill_graph(
 static bool test_glm_dsa_direct_sparse_decode_graph(
         const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
     try {
+        scoped_test_env direct_decode_cap("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K", "1024");
         scoped_test_env graph_reuse_disabled("LLAMA_GRAPH_REUSE_DISABLE", "1");
         const glm_dsa_graph_op_counts counts = run_glm_dsa_decode_graph_after_prefill(seed, devs);
 
@@ -692,22 +693,21 @@ static bool test_glm_dsa_compact_min_kv_decode_graph(
     }
 }
 
-static bool test_glm_dsa_default_compact_threshold_decode_graph(
+static bool test_glm_dsa_default_compact_decode_graph(
         const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
     try {
-        scoped_test_env compact_decode_cap("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K", "4");
         scoped_test_env graph_reuse_disabled("LLAMA_GRAPH_REUSE_DISABLE", "1");
         const glm_dsa_graph_op_counts counts = run_glm_dsa_decode_graph_after_prefill(seed, devs);
 
         if (counts.compact_get_rows == 0 || counts.flash_attn == 0 || counts.sparse_mask != 0 || counts.sparse_mask_nodes != 0 || counts.dsa_sparse_attn != 0) {
             fprintf(stderr,
-                    "GLM_DSA default compact-threshold decode graph counted total=%d compact_get_rows=%d flash_attn=%d sparse_mask=%d sparse_mask_nodes=%d dsa_sparse_attn=%d\n",
+                    "GLM_DSA default compact decode graph counted total=%d compact_get_rows=%d flash_attn=%d sparse_mask=%d sparse_mask_nodes=%d dsa_sparse_attn=%d\n",
                     counts.total, counts.compact_get_rows, counts.flash_attn, counts.sparse_mask, counts.sparse_mask_nodes, counts.dsa_sparse_attn);
             return false;
         }
         return true;
     } catch (const std::exception & err) {
-        fprintf(stderr, "GLM_DSA default compact-threshold decode graph test failed: %s\n", err.what());
+        fprintf(stderr, "GLM_DSA default compact decode graph test failed: %s\n", err.what());
         return false;
     }
 }
@@ -1070,7 +1070,7 @@ static int test_backends(const llm_arch target_arch, const size_t seed, const gg
                 test_glm_dsa_direct_sparse_decode_graph(seed, {}) &&
                 test_glm_dsa_compact_decode_graph(seed, {}) &&
                 test_glm_dsa_compact_min_kv_decode_graph(seed, {}) &&
-                test_glm_dsa_default_compact_threshold_decode_graph(seed, {}) &&
+                test_glm_dsa_default_compact_decode_graph(seed, {}) &&
                 test_glm_dsa_compact_disabled_decode_graph(seed, {}) &&
                 test_glm_dsa_verify_dense_graph(seed, {}) &&
                 test_glm_dsa_short_prefill_dense_graph(seed, {}) &&
