+        /*.top_k       =*/ (int32_t) fusion.ids->ne[0],
+        /*.has_bias    =*/ fusion.bias ? 1 : 0,
+        /*.norm        =*/ 1,
+        /*._pad0       =*/ 0,
+        /*._pad1       =*/ 0,
+        /*._pad2       =*/ 0,
+        /*.scale       =*/ scale,
+        /*.clamp_min   =*/ clamp_min,
+        /*.logits_nb0  =*/ nb_logits0,
+        /*.logits_nb1  =*/ nb_logits1,
+        /*.bias_nb0    =*/ nb_bias0,
+        /*.ids_nb0     =*/ nb_ids0,
+        /*.ids_nb1     =*/ nb_ids1,
+        /*.weights_nb1 =*/ nb_weights1,
+        /*.weights_nb2 =*/ nb_weights2,
