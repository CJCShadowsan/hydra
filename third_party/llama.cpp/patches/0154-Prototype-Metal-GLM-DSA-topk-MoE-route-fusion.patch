+            args.n_expert,
+            args.n_tokens,
+            args.top_k,
+            fusion.n_fuse,
+            (double) args.scale,
+            args.n_tokens,
+            nth);
+    }
+    ggml_metal_encoder_dispatch_threadgroups(enc, args.n_tokens, 1, 1, nth, 1, 1);
+
+    return fusion.n_fuse;
+}
