diff --git a/src/llama-hparams.h b/src/llama-hparams.h
index 2eadeb214..e92be6b92 100644
--- a/src/llama-hparams.h
+++ b/src/llama-hparams.h
@@ -225,6 +225,12 @@ struct llama_hparams {
     uint32_t indexer_n_head    = 0;
     uint32_t indexer_head_size = 0;
     uint32_t indexer_top_k     = 0;
+    uint32_t indexer_top_k_frequency          = 0;
+    uint32_t indexer_skip_top_k_offset        = 0;
+    bool     indexer_share_for_mtp_iteration = false;
+    bool     indexer_rope_interleave         = false;
+    bool     rope_interleave                 = false;
+    std::array<int32_t, LLAMA_MAX_LAYERS> indexer_is_shared = {};
 
     // qwen3vl deepstack
     // When parsed from GGUF, this implies the first N layers consume the first
diff --git a/src/models/glm-dsa.cpp b/src/models/glm-dsa.cpp
index d70673471..a643d2cf4 100644
--- a/src/models/glm-dsa.cpp
+++ b/src/models/glm-dsa.cpp
@@ -25,6 +25,15 @@ void llama_model_glm_dsa::load_arch_hparams(llama_model_loader & ml) {
     ml.get_key(LLM_KV_ATTENTION_INDEXER_HEAD_COUNT, hparams.indexer_n_head);
     ml.get_key(LLM_KV_ATTENTION_INDEXER_KEY_LENGTH, hparams.indexer_head_size);
     ml.get_key(LLM_KV_ATTENTION_INDEXER_TOP_K,      hparams.indexer_top_k);
+    ml.get_key(LLM_KV_ATTENTION_INDEXER_TOP_K_FREQUENCY,
+            hparams.indexer_top_k_frequency, false);
+    ml.get_key(LLM_KV_ATTENTION_INDEXER_SKIP_TOP_K_OFFSET,
+            hparams.indexer_skip_top_k_offset, false);
+    ml.get_key(LLM_KV_ATTENTION_INDEXER_SHARE_FOR_MTP_ITERATION,
+            hparams.indexer_share_for_mtp_iteration, false);
+    ml.get_key(LLM_KV_ATTENTION_INDEXER_ROPE_INTERLEAVE,
+            hparams.indexer_rope_interleave, false);
+    ml.get_key(LLM_KV_ROPE_INTERLEAVE, hparams.rope_interleave, false);
 
     // Expert gating function (GLM-4.5 uses sigmoid)
     ml.get_key(LLM_KV_EXPERT_GATING_FUNC,          hparams.expert_gating_func, false);
@@ -36,8 +45,25 @@ void llama_model_glm_dsa::load_arch_hparams(llama_model_loader & ml) {
     ml.get_key(LLM_KV_NEXTN_PREDICT_LAYERS, hparams.n_layer_nextn, false);
     GGML_ASSERT(hparams.n_layer_nextn < hparams.n_layer_all && "n_layer_nextn must be < n_layer_impl");
 
+    std::vector<std::string> indexer_types;
+    if (ml.get_arr(LLM_KV_ATTENTION_INDEXER_TYPES, indexer_types, false)) {
+        if (indexer_types.size() != hparams.n_layer()) {
+            throw std::runtime_error("GLM_DSA indexer type count must match decoder layer count");
+        }
+
+        for (uint32_t il = 0; il < indexer_types.size(); ++il) {
+            if (indexer_types[il] == "full") {
+                hparams.indexer_is_shared[il] = 0;
+            } else if (indexer_types[il] == "shared") {
+                hparams.indexer_is_shared[il] = 1;
+            } else {
+                throw std::runtime_error("unknown GLM_DSA indexer type: " + indexer_types[il]);
+            }
+        }
+    }
+
     switch (hparams.n_layer()) {
-        case 79: type = LLM_TYPE_744B_A40B; break;
+        case 78: type = LLM_TYPE_744B_A40B; break;
         default: type = LLM_TYPE_UNKNOWN;
     }
 }
