From 7b07e1ec593b6c9a98da62a621d64e7496ebe664 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 14:15:54 +1000
Subject: [PATCH] Gate GLM DSA MoE phase report

---
 scripts/glm52-phase-e-moe-report.sh | 60 +++++++++++++++++++++++++++++
 1 file changed, 60 insertions(+)

diff --git a/scripts/glm52-phase-e-moe-report.sh b/scripts/glm52-phase-e-moe-report.sh
index 5496f7db3..9a0d0bdd4 100755
--- a/scripts/glm52-phase-e-moe-report.sh
+++ b/scripts/glm52-phase-e-moe-report.sh
@@ -58,6 +58,7 @@ moe_filter='n_embd=6144|m=2048|m=4096|m=6144|n_tokens=1|n_tokens=4|n_embd=256'
 python3 - "${moe_log}" "${summary}" <<'PY'
 import re
 import sys
+import os
 from pathlib import Path
 
 moe_log, summary = map(Path, sys.argv[1:])
@@ -136,6 +137,34 @@ estimated_decode = None
 if route and weighted_1 and gate_up and down and moe_act_fused:
     estimated_decode = route["us"] + 2.0 * gate_up["us"] + moe_act_fused["us"] + down["us"] + weighted_1["us"]
 
+require_gates = os.environ.get("GLM52_PHASE_E_REQUIRE_GATES", "0") != "0"
+
+def gate_fail(message):
+    print(f"error: {message}", file=sys.stderr)
+    sys.exit(2)
+
+if require_gates:
+    required_rows = {
+        "route/top-k": route,
+        "weighted sum": weighted_1,
+        "routed q2_K gate/up": gate_up,
+        "routed q3_K down": down,
+        "routed q2_K down alternative": down_q2,
+        "routed fused SwiGLU": moe_act_fused,
+        "small routed fused whole graph": consumer_q_fused,
+        "shared fused GLU": shexp_fused,
+        "shared fused SwiGLU component": shexp_swiglu,
+    }
+    missing = [name for name, row in required_rows.items() if row is None]
+    if missing:
+        gate_fail("missing Phase E MoE gate rows: " + ", ".join(missing))
+    if estimated_decode is None:
+        gate_fail("missing estimated routed FFN decode cost")
+    if down_q2["us"] >= down["us"]:
+        gate_fail(f"expected q2_K down alternative to be faster than q3_K down, got {down_q2['us']:.2f} us vs {down['us']:.2f} us")
+    if moe_act_fused["us"] >= estimated_decode * 0.05:
+        gate_fail(f"expected routed fused SwiGLU to stay below 5% of routed FFN estimate, got {moe_act_fused['us']:.2f} us of {estimated_decode:.2f} us")
+
 lines = [
     "# GLM-5.2 Phase E MoE Report",
     "",
@@ -144,6 +173,7 @@ lines = [
     "## Inputs",
     "",
     f"- MoE perf: `{moe_log.name}`",
+    f"- Phase E gates: `{'required' if require_gates else 'advisory'}`",
     "",
     "## Decode Components",
     "",
@@ -271,6 +301,7 @@ if [[ "${GLM52_PHASE_E_KERNEL_SWEEP:-0}" != "0" ]]; then
     done
 
     python3 - "${summary}" "${sweep_dir}" <<'PY'
+import os
 import re
 import sys
 from pathlib import Path
@@ -339,6 +370,35 @@ best_q3 = min((row for _, row in q3_rows if row), key=lambda row: row["us"], def
 default_nr0_q3 = next((row for nr0, row in q3_nr0_rows if nr0 == 4 and row), None)
 best_nr0_q3 = min((row for _, row in q3_nr0_rows if row), key=lambda row: row["us"], default=None)
 
+require_gates = os.environ.get("GLM52_PHASE_E_REQUIRE_GATES", "0") != "0"
+
+def gate_fail(message):
+    print(f"error: {message}", file=sys.stderr)
+    sys.exit(2)
+
+if require_gates:
+    missing = []
+    if forced_q3 is None:
+        missing.append("forced q3_K mul_mm_id row")
+    missing.extend(
+        f"q3_K mul_mv_id nsg={nsg}"
+        for nsg, row in q3_rows
+        if row is None
+    )
+    missing.extend(
+        f"q3_K mul_mv_id nr0={nr0}"
+        for nr0, row in q3_nr0_rows
+        if row is None
+    )
+    if missing:
+        gate_fail("missing Phase E kernel sweep rows: " + ", ".join(missing))
+    if forced_q3["us"] <= default_q3["us"] * 2.0:
+        gate_fail(
+            "expected forced q3_K mul_mm_id to be at least 2x slower than "
+            f"default mul_mv_id, got {forced_q3['us']:.2f} us vs "
+            f"{default_q3['us']:.2f} us"
+        )
+
 lines.extend(["", "### Kernel Sweep Notes", ""])
 if forced_q3 and default_q3:
     lines.append(f"- Forcing `mul_mm_id` at one token measured `{forced_q3['us']:.2f} us` for q3_K down versus `{default_q3['us']:.2f} us` on the default `mul_mv_id` path; keep one-token decode on matrix-vector kernels.")
-- 
2.53.0

