From 275abbe0296239ab33504e51aa2acd72464e1d73 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 08:46:55 +1000
Subject: [PATCH] Improve GLM-DSA sideband width errors

---
 src/skippy.cpp | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 59cd59a98..ff0b4b46c 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1501,7 +1501,16 @@ static enum skippy_status skippy_validate_frame_input(
         }
         const uint32_t expected_top_k = skippy_glm_dsa_sideband_top_k_count(session, expected_token_count);
         if (actual_top_k != expected_top_k) {
-            skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "GLM-DSA top-k sideband width does not match expected IndexShare width");
+            char message[256];
+            std::snprintf(
+                    message,
+                    sizeof(message),
+                    "GLM-DSA top-k sideband width does not match expected IndexShare width: expected=%u actual=%u tokens=%zu sideband_bytes=%zu",
+                    expected_top_k,
+                    actual_top_k,
+                    expected_token_count,
+                    sideband_bytes);
+            skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, message);
             return SKIPPY_STATUS_INVALID_ARGUMENT;
         }
     } else {
