+        scoped_test_env dense_mask_limit("SKIPPY_GLM_DSA_DENSE_SPARSE_MASK_MAX_BYTES", "1");
+        scoped_test_env large_prefill_enabled("SKIPPY_GLM_DSA_ENABLE_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL", "1");
+        const glm_dsa_graph_op_counts counts = run_glm_dsa_prefill_graph(seed, devs, 16);
