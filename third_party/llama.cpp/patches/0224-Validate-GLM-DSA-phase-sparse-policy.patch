     return parsed <= 0 ? INT64_MAX : parsed;
 }
 
+static int64_t skippy_glm_dsa_compact_flash_min_kv() {
+    const char * value = getenv("SKIPPY_GLM_DSA_COMPACT_FLASH_MIN_KV");
+    if (value == nullptr || value[0] == '\0') {
+        const skippy_graph_filter & filter = skippy_graph_get_filter();
+        if (filter.glm_dsa_policy_profile != 0 && filter.glm_dsa_compact_flash_min_kv > 0) {
+            return filter.glm_dsa_compact_flash_min_kv;
+        }
+        return 0;
+    }
+
+    const int64_t parsed = atoll(value);
+    return parsed <= 0 ? 0 : parsed;
+}
