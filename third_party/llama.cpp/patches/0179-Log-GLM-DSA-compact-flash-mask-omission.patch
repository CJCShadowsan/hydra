From 38aeaa75ba64b2e7f23e340048b95c30a1b4c090 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 07:30:24 +1000
Subject: [PATCH] Log GLM DSA compact flash mask omission

---
 src/llama-graph.cpp | 29 +++++++++++++++++++++++++++++
 1 file changed, 29 insertions(+)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 7f4ec39f0..790c84cbe 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -419,6 +419,27 @@ static void skippy_glm_dsa_log_compact_flash_policy(
             selector_reason);
 }
 
+static void skippy_glm_dsa_log_compact_flash_mask(
+        int     layer,
+        bool    omitted_mla_kq_mask,
+        int64_t visible_kv,
+        int64_t ubatch_tokens,
+        int64_t streams,
+        int64_t max_top_k) {
+    if (!skippy_glm_dsa_compact_flash_policy_log_enabled()) {
+        return;
+    }
+
+    LLAMA_LOG_INFO(
+            "skippy: glm_dsa_compact_flash_mask layer=%d omitted_mla_kq_mask=%d visible_kv=%lld ubatch_tokens=%lld streams=%lld max_top_k=%lld\n",
+            layer,
+            omitted_mla_kq_mask ? 1 : 0,
+            (long long) visible_kv,
+            (long long) ubatch_tokens,
+            (long long) streams,
+            (long long) max_top_k);
+}
+
 void skippy_graph_set_filter(const skippy_graph_filter & filter) {
     g_skippy_graph_filter = filter;
 }
@@ -3326,6 +3347,14 @@ ggml_tensor * llm_graph_context::build_attn(
             sparse_policy.compact_selector_reason);
 
     if (sparse_policy.use_compact_flash_attn()) {
+        skippy_glm_dsa_log_compact_flash_mask(
+                il,
+                kq_mask == nullptr,
+                n_sparse_kv,
+                ubatch.n_tokens,
+                n_direct_sparse_stream,
+                n_sparse_top_k);
+
         ggml_tensor * cur = build_attn_mha_dsa_compact_flash(q, k, v, top_k_3d, v_mla, kq_scale, il);
         cb(cur, "kqv_out", il);
 
-- 
2.53.0

