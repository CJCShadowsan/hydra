From 531fc82011d281f345faaa72b7e947f5103db965 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 08:30:55 +1000
Subject: [PATCH 214/214] Add typed GLM DSA runtime policy

---
 include/skippy.h        | 17 ++++++++++++++++
 include/skippy/common.h |  2 +-
 src/llama-graph.cpp     | 43 +++++++++++++++++++++++++++++++++++++++++
 src/llama-graph.h       |  6 ++++++
 src/skippy.cpp          | 10 ++++++++--
 5 files changed, 75 insertions(+), 3 deletions(-)

diff --git a/include/skippy.h b/include/skippy.h
index d2f4951d6..20e501473 100644
--- a/include/skippy.h
+++ b/include/skippy.h
@@ -45,6 +45,14 @@ enum skippy_activation_layout {
 #define SKIPPY_ACTIVATION_FLAG_GEMMA3N_ALTUP   (UINT64_C(1) << 1)
 #define SKIPPY_ACTIVATION_FLAG_GLM_DSA_TOP_K   (UINT64_C(1) << 3)
 
+#define SKIPPY_GLM_DSA_POLICY_PROFILE_NONE     0
+#define SKIPPY_GLM_DSA_POLICY_PROFILE_V1       1
+
+#define SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_ATTN                  (UINT32_C(1) << 0)
+#define SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_PREFILL               (UINT32_C(1) << 1)
+#define SKIPPY_GLM_DSA_POLICY_DISABLE_COMPACT_FLASH_ATTN          (UINT32_C(1) << 2)
+#define SKIPPY_GLM_DSA_POLICY_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL (UINT32_C(1) << 3)
+
 struct skippy_model;
 struct skippy_session;
 struct skippy_model_info;
@@ -79,6 +87,15 @@ struct skippy_runtime_config {
     // "Vulkan1", or "CPU". When set, skippy loads the model only on that
     // backend device instead of relying on llama.cpp default device ordering.
     const char * selected_backend_device;
+
+    // Optional GLM-DSA execution policy resolved from package generation
+    // metadata. Zero values preserve llama.cpp built-in/env behavior.
+    int32_t  glm_dsa_policy_profile;
+    uint32_t glm_dsa_policy_flags;
+    int32_t  glm_dsa_short_prefill_max_tokens;
+    int32_t  glm_dsa_direct_sparse_decode_max_top_k;
+    uint64_t glm_dsa_dense_sparse_mask_max_bytes;
+    int32_t  glm_dsa_compact_flash_min_kv;
 };
 
 struct skippy_tensor_info {
diff --git a/include/skippy/common.h b/include/skippy/common.h
index b7186bc9e..14084eeeb 100644
--- a/include/skippy/common.h
+++ b/include/skippy/common.h
@@ -26,7 +26,7 @@ extern "C" {
 
 #define SKIPPY_ABI_VERSION_MAJOR 0
 #define SKIPPY_ABI_VERSION_MINOR 1
-#define SKIPPY_ABI_VERSION_PATCH 30
+#define SKIPPY_ABI_VERSION_PATCH 31
 
 enum skippy_feature {
     SKIPPY_FEATURE_RUNTIME_SLICE          = 1 << 0,
diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index bc713d04e..5a1308aac 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -25,6 +25,11 @@ static thread_local skippy_activation_rwkv7_v_first g_skippy_rwkv7_v_first;
 static thread_local skippy_activation_gemma3n_altup g_skippy_gemma3n_altup;
 static thread_local skippy_activation_glm_dsa_top_k g_skippy_glm_dsa_top_k;
 
+static constexpr uint32_t LLAMA_SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_ATTN                   = UINT32_C(1) << 0;
+static constexpr uint32_t LLAMA_SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_PREFILL                = UINT32_C(1) << 1;
+static constexpr uint32_t LLAMA_SKIPPY_GLM_DSA_POLICY_DISABLE_COMPACT_FLASH_ATTN           = UINT32_C(1) << 2;
+static constexpr uint32_t LLAMA_SKIPPY_GLM_DSA_POLICY_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL = UINT32_C(1) << 3;
+
 static bool skippy_env_enabled(const char * name) {
     const char * value = getenv(name);
     return value != nullptr && strcmp(value, "0") != 0 && strcmp(value, "false") != 0 && strcmp(value, "FALSE") != 0;
@@ -44,11 +49,23 @@ static bool skippy_glm_dsa_direct_sparse_attn_enabled() {
         skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_DIRECT_SPARSE_ATTN")) {
         return false;
     }
+    if (skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_ATTN")) {
+        return true;
+    }
+    const skippy_graph_filter & filter = skippy_graph_get_filter();
+    if (filter.glm_dsa_policy_profile != 0) {
+        return (filter.glm_dsa_policy_flags & LLAMA_SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_ATTN) != 0;
+    }
 
     return true;
 }
 
 static bool skippy_glm_dsa_compact_flash_attn_disabled() {
+    const skippy_graph_filter & filter = skippy_graph_get_filter();
+    if (filter.glm_dsa_policy_profile != 0 &&
+            (filter.glm_dsa_policy_flags & LLAMA_SKIPPY_GLM_DSA_POLICY_DISABLE_COMPACT_FLASH_ATTN) != 0) {
+        return true;
+    }
     return skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_COMPACT_FLASH_ATTN");
 }
 
@@ -65,17 +82,35 @@ static bool skippy_glm_dsa_direct_sparse_prefill_enabled() {
         skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_DIRECT_SPARSE_PREFILL")) {
         return false;
     }
+    if (skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_PREFILL")) {
+        return true;
+    }
+    const skippy_graph_filter & filter = skippy_graph_get_filter();
+    if (filter.glm_dsa_policy_profile != 0) {
+        return (filter.glm_dsa_policy_flags & LLAMA_SKIPPY_GLM_DSA_POLICY_DIRECT_SPARSE_PREFILL) != 0;
+    }
 
     return true;
 }
 
 static bool skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled() {
+    if (skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL")) {
+        return true;
+    }
+    const skippy_graph_filter & filter = skippy_graph_get_filter();
+    if (filter.glm_dsa_policy_profile != 0) {
+        return (filter.glm_dsa_policy_flags & LLAMA_SKIPPY_GLM_DSA_POLICY_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL) != 0;
+    }
     return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_UNPROVEN_LARGE_DIRECT_SPARSE_PREFILL");
 }
 
 static int64_t skippy_glm_dsa_direct_sparse_prefill_max_tokens() {
     const char * value = getenv("SKIPPY_GLM_DSA_DIRECT_SPARSE_PREFILL_MAX_TOKENS");
     if (value == nullptr || value[0] == '\0') {
+        const skippy_graph_filter & filter = skippy_graph_get_filter();
+        if (filter.glm_dsa_policy_profile != 0 && filter.glm_dsa_short_prefill_max_tokens > 0) {
+            return filter.glm_dsa_short_prefill_max_tokens;
+        }
         return 8;
     }
 
@@ -86,6 +121,10 @@ static int64_t skippy_glm_dsa_direct_sparse_prefill_max_tokens() {
 static int64_t skippy_glm_dsa_dense_sparse_mask_max_bytes() {
     const char * value = getenv("SKIPPY_GLM_DSA_DENSE_SPARSE_MASK_MAX_BYTES");
     if (value == nullptr || value[0] == '\0') {
+        const skippy_graph_filter & filter = skippy_graph_get_filter();
+        if (filter.glm_dsa_policy_profile != 0 && filter.glm_dsa_dense_sparse_mask_max_bytes > 0) {
+            return (int64_t) filter.glm_dsa_dense_sparse_mask_max_bytes;
+        }
         return 512LL * 1024LL * 1024LL;
     }
 
@@ -203,6 +242,10 @@ static constexpr int64_t LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K =
 static int64_t skippy_glm_dsa_direct_sparse_decode_max_top_k() {
     const char * value = getenv("SKIPPY_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K");
     if (value == nullptr || value[0] == '\0') {
+        const skippy_graph_filter & filter = skippy_graph_get_filter();
+        if (filter.glm_dsa_policy_profile != 0 && filter.glm_dsa_direct_sparse_decode_max_top_k > 0) {
+            return filter.glm_dsa_direct_sparse_decode_max_top_k;
+        }
         return LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_DEFAULT_MAX_TOP_K;
     }
 
diff --git a/src/llama-graph.h b/src/llama-graph.h
index 4c8bab6f1..4a7420b1b 100644
--- a/src/llama-graph.h
+++ b/src/llama-graph.h
@@ -34,6 +34,12 @@ struct skippy_graph_filter {
     int32_t layer_end = 0;
     bool include_embeddings = false;
     bool include_output = false;
+    int32_t glm_dsa_policy_profile = 0;
+    uint32_t glm_dsa_policy_flags = 0;
+    int32_t glm_dsa_short_prefill_max_tokens = 0;
+    int32_t glm_dsa_direct_sparse_decode_max_top_k = 0;
+    uint64_t glm_dsa_dense_sparse_mask_max_bytes = 0;
+    int32_t glm_dsa_compact_flash_min_kv = 0;
 };
 
 struct skippy_activation_tokens {
diff --git a/src/skippy.cpp b/src/skippy.cpp
index 3dd2def9c..bb236814e 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -991,13 +991,19 @@ struct skippy_filter_scope {
 
 struct skippy_graph_filter_scope {
     explicit skippy_graph_filter_scope(const skippy_runtime_config * config) {
-        if (config != nullptr && config->filter_tensors_on_load) {
+        if (config != nullptr && (config->filter_tensors_on_load || config->glm_dsa_policy_profile != 0)) {
             skippy_graph_filter filter;
-            filter.enabled = true;
+            filter.enabled = config->filter_tensors_on_load;
             filter.layer_start = config->layer_start;
             filter.layer_end = config->layer_end;
             filter.include_embeddings = config->include_embeddings;
             filter.include_output = config->include_output;
+            filter.glm_dsa_policy_profile = config->glm_dsa_policy_profile;
+            filter.glm_dsa_policy_flags = config->glm_dsa_policy_flags;
+            filter.glm_dsa_short_prefill_max_tokens = config->glm_dsa_short_prefill_max_tokens;
+            filter.glm_dsa_direct_sparse_decode_max_top_k = config->glm_dsa_direct_sparse_decode_max_top_k;
+            filter.glm_dsa_dense_sparse_mask_max_bytes = config->glm_dsa_dense_sparse_mask_max_bytes;
+            filter.glm_dsa_compact_flash_min_kv = config->glm_dsa_compact_flash_min_kv;
             skippy_graph_set_filter(filter);
             enabled = true;
         }
-- 
2.53.0

