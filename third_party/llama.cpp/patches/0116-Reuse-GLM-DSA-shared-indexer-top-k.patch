From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: mesh-llm <mesh-llm@example.invalid>
Date: Mon, 22 Jun 2026 12:30:00 +0000
Subject: [PATCH] Reuse GLM_DSA shared indexer top-k

GLM-5.2 does not run a fresh DSA lightning indexer on every decoder layer.
Its `indexer_types` schedule marks some layers as `full` and intervening
layers as `shared`; shared layers reuse the previous full layer's top-k token
indices.

Carry the previous top-k tensor through the DeepSeek32 DSA graph and, when the
graph is used for GLM_DSA, skip indexer q/k/scoring on shared layers. Also make
GLM_DSA shared-layer indexer tensors optional and skipped during tensor loading,
because correctly converted GLM checkpoints do not need per-layer indexer
weights for those shared layers.

This keeps DeepSeek32 behavior unchanged: without GLM_DSA shared metadata every
layer still computes its own indexer top-k.
---
 src/models/deepseek32.cpp | 11 ++++++++++-
 src/models/glm-dsa.cpp   | 15 +++++++++------
 2 files changed, 19 insertions(+), 7 deletions(-)

diff --git a/src/models/deepseek32.cpp b/src/models/deepseek32.cpp
index 9a20e2ce9..f85aa8af1 100644
--- a/src/models/deepseek32.cpp
+++ b/src/models/deepseek32.cpp
@@ -201,6 +201,7 @@ llama_model_deepseek32::graph::graph(const llama_model & model, const llm_graph_
     llm_graph_input_attn_k_dsa * inp_attn_dsa = build_attn_inp_k_dsa();
 
     ggml_tensor * inp_out_ids = build_inp_out_ids();
+    ggml_tensor * prev_top_k = nullptr;
 
     for (int il = 0; il < n_layer; ++il) {
         ggml_tensor * inpSA = inpL;
@@ -218,9 +219,16 @@ llama_model_deepseek32::graph::graph(const llama_model & model, const llm_graph_
             cb(qr, "qr", il);
 
             ggml_tensor * top_k = nullptr;
+            const bool reuse_previous_top_k =
+                arch == LLM_ARCH_GLM_DSA && hparams.indexer_is_shared[il] != 0;
 
             // lightning indexer
-            {
+            if (reuse_previous_top_k) {
+                if (prev_top_k == nullptr) {
+                    throw std::runtime_error("GLM_DSA shared indexer layer has no previous top-k");
+                }
+                top_k = prev_top_k;
+            } else {
                 ggml_tensor * indexer_q = ggml_mul_mat(ctx0, model.layers[il].indexer_attn_q_b, qr);
                 cb(indexer_q, "indexer_q", il);
 
@@ -344,6 +352,7 @@ llama_model_deepseek32::graph::graph(const llama_model & model, const llm_graph_
                 top_k = ggml_cont(ctx0, ggml_top_k(ctx0, indexer_score, n_top_k));
                 cb(top_k, "top_k", il);
             }
+            prev_top_k = top_k;
 
             ggml_tensor * q = ggml_mul_mat(ctx0, model.layers[il].wq_b, qr);
             cb(q, "q", il);
diff --git a/src/models/glm-dsa.cpp b/src/models/glm-dsa.cpp
index a643d2cf4..1857350e3 100644
--- a/src/models/glm-dsa.cpp
+++ b/src/models/glm-dsa.cpp
@@ -122,11 +122,14 @@ void llama_model_glm_dsa::load_arch_tensors(llama_model_loader &) {
         layer.ffn_norm = create_tensor(tn(LLM_TENSOR_FFN_NORM, "weight", i), {n_embd}, flags);
 
         // DSA indexer
-        layer.indexer_k_norm   = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "weight", i), {hparams.indexer_head_size}, flags);
-        layer.indexer_k_norm_b = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "bias",   i), {hparams.indexer_head_size}, flags);
-        layer.indexer_proj     = create_tensor(tn(LLM_TENSOR_INDEXER_PROJ,     "weight", i), {n_embd, hparams.indexer_n_head}, flags);
-        layer.indexer_attn_k   = create_tensor(tn(LLM_TENSOR_INDEXER_ATTN_K,   "weight", i), {n_embd, hparams.indexer_head_size}, flags);
-        layer.indexer_attn_q_b = create_tensor(tn(LLM_TENSOR_INDEXER_ATTN_Q_B, "weight", i), {q_lora_rank, hparams.indexer_n_head * hparams.indexer_head_size}, flags);
+        const bool shared_indexer_layer =
+            i < (int) hparams.n_layer() && hparams.indexer_is_shared[i] != 0;
+        const int indexer_flags = flags | (shared_indexer_layer ? (TENSOR_NOT_REQUIRED | TENSOR_SKIP) : 0);
+        layer.indexer_k_norm   = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "weight", i), {hparams.indexer_head_size}, indexer_flags);
+        layer.indexer_k_norm_b = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "bias",   i), {hparams.indexer_head_size}, indexer_flags);
+        layer.indexer_proj     = create_tensor(tn(LLM_TENSOR_INDEXER_PROJ,     "weight", i), {n_embd, hparams.indexer_n_head}, indexer_flags);
+        layer.indexer_attn_k   = create_tensor(tn(LLM_TENSOR_INDEXER_ATTN_K,   "weight", i), {n_embd, hparams.indexer_head_size}, indexer_flags);
+        layer.indexer_attn_q_b = create_tensor(tn(LLM_TENSOR_INDEXER_ATTN_Q_B, "weight", i), {q_lora_rank, hparams.indexer_n_head * hparams.indexer_head_size}, indexer_flags);
         if (i < (int) hparams.n_layer_dense_lead) {
             layer.ffn_gate = create_tensor(tn(LLM_TENSOR_FFN_GATE, "weight", i), {n_embd,   n_ff}, flags);
             layer.ffn_down = create_tensor(tn(LLM_TENSOR_FFN_DOWN, "weight", i), {  n_ff, n_embd}, flags);
