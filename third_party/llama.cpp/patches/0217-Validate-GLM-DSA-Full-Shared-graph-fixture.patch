Subject: [PATCH 217/217] Validate GLM DSA Full Shared graph fixture

---
 src/models/glm-dsa.cpp     |  9 ++++-
 tests/test-llama-archs.cpp | 73 ++++++++++++++++++++++++++++++++++++--
 2 files changed, 78 insertions(+), 4 deletions(-)

diff --git a/src/models/glm-dsa.cpp b/src/models/glm-dsa.cpp
index 0a392f8ff..617777690 100644
--- a/src/models/glm-dsa.cpp
+++ b/src/models/glm-dsa.cpp
@@ -565,7 +565,14 @@ void llama_model_glm_dsa::load_arch_tensors(llama_model_loader &) {
 
         // GLM-DSA IndexShare metadata describes target decoder layers only. Native MTP
         // blocks can still carry full decoder-shaped tensors and complete indexer tensors.
-        const int indexer_flags = flags | TENSOR_NOT_REQUIRED;
+        bool indexer_metadata_matched = false;
+        const bool indexer_metadata_full =
+                i < (int) hparams.n_layer() &&
+                llama_glm_dsa_metadata_layer_is_full(hparams, i, &indexer_metadata_matched);
+        const bool skip_virtual_indexer =
+                indexer_metadata_matched && !indexer_metadata_full;
+        const int indexer_flags =
+                flags | TENSOR_NOT_REQUIRED | (skip_virtual_indexer ? TENSOR_SKIP_IF_VIRTUAL : 0);
         layer.indexer_k_norm   = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "weight", i), {hparams.indexer_head_size}, indexer_flags);
         layer.indexer_k_norm_b = create_tensor(tn(LLM_TENSOR_INDEXER_K_NORM,   "bias",   i), {hparams.indexer_head_size}, indexer_flags);
         layer.indexer_proj     = create_tensor(tn(LLM_TENSOR_INDEXER_PROJ,     "weight", i), {n_embd, hparams.indexer_n_head}, indexer_flags);
diff --git a/tests/test-llama-archs.cpp b/tests/test-llama-archs.cpp
index f83024081..6c3c863e6 100644
--- a/tests/test-llama-archs.cpp
+++ b/tests/test-llama-archs.cpp
@@ -81,6 +81,7 @@ enum class glm_dsa_indexshare_fixture {
     DEFAULT,
     CONFLICTING_METADATA,
     SHARED_FIRST,
+    FULL_SHARED,
 };
 
 static gguf_context_ptr get_gguf_ctx(
@@ -215,6 +216,10 @@ static gguf_context_ptr get_gguf_ctx(
             ms.add_kv(LLM_KV_ATTENTION_INDEXER_TYPES, std::vector<std::string>({"full", "shared"}));
         } else if (glm_dsa_indexshare == glm_dsa_indexshare_fixture::SHARED_FIRST) {
             ms.add_kv(LLM_KV_ATTENTION_INDEXER_TYPES, std::vector<std::string>({"shared", "full"}));
+        } else if (glm_dsa_indexshare == glm_dsa_indexshare_fixture::FULL_SHARED) {
+            ms.add_kv(LLM_KV_ATTENTION_INDEXER_TOP_K_FREQUENCY, uint32_t(2));
+            ms.add_kv(LLM_KV_ATTENTION_INDEXER_SKIP_TOP_K_OFFSET, uint32_t(1));
+            ms.add_kv(LLM_KV_ATTENTION_INDEXER_TYPES, std::vector<std::string>({"full", "shared"}));
         } else {
             ms.add_kv(LLM_KV_ATTENTION_INDEXER_TOP_K_FREQUENCY, uint32_t(1));
             ms.add_kv(LLM_KV_ATTENTION_INDEXER_SKIP_TOP_K_OFFSET, uint32_t(0));
@@ -326,9 +331,34 @@ static bool test_glm_dsa_rejects_shared_first_indexshare_metadata(const size_t s
     return false;
 }
 
+struct glm_dsa_graph_op_counts {
+    int lightning_indexer = 0;
+    int top_k             = 0;
+};
+
+static bool glm_dsa_graph_op_counter_callback(ggml_tensor * tensor, bool ask, void * user_data) {
+    if (!ask) {
+        return true;
+    }
+
+    glm_dsa_graph_op_counts * counts = static_cast<glm_dsa_graph_op_counts *>(user_data);
+    if (tensor->op == GGML_OP_LIGHTNING_INDEXER) {
+        ++counts->lightning_indexer;
+    } else if (tensor->op == GGML_OP_TOP_K) {
+        if (strncmp(tensor->name, "ffn_moe_topk", strlen("ffn_moe_topk")) != 0) {
+            ++counts->top_k;
+        }
+    }
+    return true;
+}
+
+static std::vector<float> get_logits(
+        llama_model * model, llama_context * lctx, const std::vector<llama_token> & tokens, bool encode);
+
 static std::pair<llama_model_ptr, llama_context_ptr> get_model_and_ctx(
         struct gguf_context * gguf_ctx, FILE * file, const size_t seed, const std::vector<ggml_backend_dev_t> & devs,
-        const llama_split_mode split_mode = LLAMA_SPLIT_MODE_LAYER, bool encode = false) {
+        const llama_split_mode split_mode = LLAMA_SPLIT_MODE_LAYER, bool encode = false,
+        ggml_backend_sched_eval_callback cb_eval = nullptr, void * cb_eval_user_data = nullptr) {
     GGML_ASSERT((gguf_ctx == nullptr) != (file == nullptr));
     llama_model_params model_params = llama_model_default_params();
     model_params.progress_callback = silent_model_load_progress;
@@ -344,6 +374,8 @@ static std::pair<llama_model_ptr, llama_context_ptr> get_model_and_ctx(
     if (!encode) {
         ctx_params.n_ubatch = 64;
     }
+    ctx_params.cb_eval = cb_eval;
+    ctx_params.cb_eval_user_data = cb_eval_user_data;
 
     size_t tmp = seed;
     llama_model_ptr model(gguf_ctx != nullptr ?
@@ -359,6 +391,40 @@ static std::pair<llama_model_ptr, llama_context_ptr> get_model_and_ctx(
     return std::make_pair(std::move(model), std::move(lctx));
 }
 
+static bool test_glm_dsa_full_shared_indexshare_graph(
+        const size_t seed, const std::vector<ggml_backend_dev_t> & devs) {
+    try {
+        gguf_context_ptr gguf_ctx = get_gguf_ctx(
+                LLM_ARCH_GLM_DSA,
+                true,
+                glm_dsa_indexshare_fixture::FULL_SHARED);
+        glm_dsa_graph_op_counts counts;
+        auto model_ctx = get_model_and_ctx(
+                gguf_ctx.get(),
+                nullptr,
+                seed,
+                devs,
+                LLAMA_SPLIT_MODE_LAYER,
+                false,
+                glm_dsa_graph_op_counter_callback,
+                &counts);
+
+        const uint32_t n_vocab = llama_vocab_n_tokens(llama_model_get_vocab(model_ctx.first.get()));
+        const std::vector<llama_token> tokens = get_tokens(8, n_vocab, seed);
+        get_logits(model_ctx.first.get(), model_ctx.second.get(), tokens, false);
+
+        if (counts.top_k != 1 || counts.lightning_indexer != 1) {
+            fprintf(stderr, "GLM_DSA Full->Shared graph counted top_k=%d lightning_indexer=%d\n",
+                    counts.top_k, counts.lightning_indexer);
+            return false;
+        }
+        return true;
+    } catch (const std::exception & err) {
+        fprintf(stderr, "GLM_DSA Full->Shared graph test failed: %s\n", err.what());
+        return false;
+    }
+}
+
 static std::vector<float> get_logits(
         llama_model * model, llama_context * lctx, const std::vector<llama_token> & tokens, bool encode = false) {
     const uint32_t n_vocab  = llama_vocab_n_tokens(llama_model_get_vocab(model));
@@ -626,9 +692,10 @@ static int test_backends(const llm_arch target_arch, const size_t seed, const gg
     if (target_arch == LLM_ARCH_UNKNOWN || target_arch == LLM_ARCH_GLM_DSA) {
         const bool glm_dsa_contract_ok =
                 test_glm_dsa_rejects_conflicting_indexshare_metadata(seed) &&
-                test_glm_dsa_rejects_shared_first_indexshare_metadata(seed);
+                test_glm_dsa_rejects_shared_first_indexshare_metadata(seed) &&
+                test_glm_dsa_full_shared_indexshare_graph(seed, {});
         if (!glm_dsa_contract_ok) {
-            fprintf(stderr, "GLM_DSA IndexShare metadata conflict test failed\n");
+            fprintf(stderr, "GLM_DSA IndexShare metadata contract test failed\n");
             all_ok = false;
         }
     }
