     ggml_backend_tensor_set(tensor, bytes.data(), dst_offset, size);
 }
 
+static void llama_kv_cache_copy_tensor_bytes_between(
+        ggml_tensor * src,
+        size_t src_offset,
+        ggml_tensor * dst,
+        size_t dst_offset,
+        size_t size) {
+    if (src == nullptr || dst == nullptr || size == 0) {
+        return;
+    }
+    if (src == dst && src_offset == dst_offset) {
+        return;
+    }
+    std::vector<uint8_t> bytes(size);
+    ggml_backend_tensor_get(src, bytes.data(), src_offset, size);
+    ggml_backend_tensor_set(dst, bytes.data(), dst_offset, size);
+}
