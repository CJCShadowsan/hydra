+bool llama_kv_cache::stage_gather_kv_path(
+        llama_seq_id source_seq_id,
+        llama_seq_id dest_seq_id,
+        uint64_t dest_start,
+        const uint64_t * source_positions,
+        uint64_t position_count,
+        std::string & error) {
+    if (position_count == 0) {
+        error = "position_count must be greater than zero";
+        return false;
+    }
+    if (source_positions == nullptr) {
+        error = "source_positions are required";
+        return false;
+    }
+    if (source_seq_id == dest_seq_id) {
+        error = "source and destination sequence ids must differ";
+        return false;
+    }
+    if (position_count > static_cast<uint64_t>(std::numeric_limits<uint32_t>::max()) ||
+            dest_start > static_cast<uint64_t>(std::numeric_limits<llama_pos>::max()) ||
+            dest_start + position_count < dest_start ||
+            dest_start + position_count > static_cast<uint64_t>(std::numeric_limits<llama_pos>::max())) {
+        error = "gather token range is too large";
+        return false;
+    }
+    if (seq_to_stream.empty() || v_cells.empty()) {
+        error = "KV cache has no stream";
+        return false;
+    }
+    if (source_seq_id < 0 || static_cast<size_t>(source_seq_id) >= seq_to_stream.size() || source_seq_id >= LLAMA_MAX_SEQ ||
+            dest_seq_id < 0 || static_cast<size_t>(dest_seq_id) >= seq_to_stream.size() || dest_seq_id >= LLAMA_MAX_SEQ) {
+        error = "sequence id is mapped to an invalid KV stream";
+        return false;
+    }
+
+    const uint32_t source_strm = seq_to_stream[source_seq_id];
+    const uint32_t dest_strm = seq_to_stream[dest_seq_id];
+    if (source_strm >= v_cells.size() || dest_strm >= v_cells.size()) {
+        error = "sequence id is mapped to an invalid KV stream";
+        return false;
+    }
+
+    const auto & source_cells = v_cells[source_strm];
+    const uint32_t n_tokens = static_cast<uint32_t>(position_count);
+    std::vector<uint32_t> source_cell_idxs(n_tokens, std::numeric_limits<uint32_t>::max());
+    for (uint32_t i = 0; i < n_tokens; ++i) {
+        const uint64_t raw_pos = source_positions[i];
+        if (raw_pos > static_cast<uint64_t>(std::numeric_limits<llama_pos>::max())) {
+            error = "source position exceeds llama position range";
+            return false;
+        }
+        const llama_pos pos = static_cast<llama_pos>(raw_pos);
+        for (uint32_t cell = 0; cell < source_cells.size(); ++cell) {
+            if (source_cells.seq_has(cell, source_seq_id) && source_cells.pos_get(cell) == pos) {
+                source_cell_idxs[i] = cell;
+                break;
+            }
+        }
+        if (source_cell_idxs[i] == std::numeric_limits<uint32_t>::max()) {
+            error = "source position is not present in the KV cache";
+            return false;
+        }
+    }
+
+    llama_ubatch ubatch = {};
+    auto udata = std::make_shared<llama_ubatch::data_t>();
+    const uint32_t n_pos = hparams.n_pos_per_embd();
+    udata->token.resize(n_tokens);
+    udata->pos.resize(static_cast<size_t>(n_tokens) * n_pos);
+    udata->n_seq_id.resize(n_tokens, 1);
+    udata->seq_id.resize(n_tokens);
+    udata->seq_id_unq = { dest_seq_id };
+    udata->seq_idx.resize(LLAMA_MAX_SEQ, -1);
+    udata->seq_idx[dest_seq_id] = 0;
+    udata->output.resize(n_tokens, 0);
+    udata->seq_id_data.resize(n_tokens, 0);
+    for (uint32_t i = 0; i < n_tokens; ++i) {
+        const llama_pos pos = static_cast<llama_pos>(dest_start + i);
+        for (uint32_t j = 0; j < n_pos; ++j) {
+            udata->pos[static_cast<size_t>(j) * n_tokens + i] = pos;
+        }
+        udata->seq_id_data[i] = dest_seq_id;
+        udata->seq_id[i] = &udata->seq_id_data[i];
+    }
+    ubatch.b_equal_seqs = true;
+    ubatch.n_tokens = n_tokens;
+    ubatch.n_seq_tokens = n_tokens;
+    ubatch.n_seqs = 1;
+    ubatch.n_seqs_unq = 1;
+    ubatch.n_pos = n_pos;
+    ubatch.token = udata->token.data();
+    ubatch.embd = nullptr;
+    ubatch.pos = udata->pos.data();
+    ubatch.n_seq_id = udata->n_seq_id.data();
+    ubatch.seq_id = udata->seq_id.data();
+    ubatch.seq_id_unq = udata->seq_id_unq.data();
+    ubatch.seq_idx = udata->seq_idx.data();
+    ubatch.output = udata->output.data();
+    ubatch.data = std::move(udata);
+
+    seq_rm(dest_seq_id, static_cast<llama_pos>(dest_start), -1);
+    const slot_info sinfo = find_slot(ubatch, false);
+    if (sinfo.empty()) {
+        error = "failed to allocate KV cache cells for gathered path";
+        return false;
+    }
+    apply_ubatch(sinfo, ubatch);
+
+    auto & dest_cells = v_cells[dest_strm];
+    bool copied_any_layer = false;
+    for (const auto & layer : layers) {
+        if (layer.k_stream.size() <= source_strm || layer.k_stream.size() <= dest_strm) {
+            continue;
+        }
+        auto * k_src = layer.k_stream[source_strm];
+        auto * k_dst = layer.k_stream[dest_strm];
+        if (k_src == nullptr || k_dst == nullptr) {
+            continue;
+        }
+        copied_any_layer = true;
+        const size_t k_row_bytes = ggml_row_size(k_src->type, hparams.n_embd_k_gqa(layer.il));
+        if (k_row_bytes != ggml_row_size(k_dst->type, hparams.n_embd_k_gqa(layer.il))) {
+            error = "source and destination K row layouts differ";
+            return false;
+        }
+        for (uint32_t i = 0; i < n_tokens; ++i) {
+            llama_kv_cache_copy_tensor_bytes_between(
+                    k_src,
+                    static_cast<size_t>(source_cell_idxs[i]) * k_row_bytes,
+                    k_dst,
+                    static_cast<size_t>(sinfo.idxs[0][i]) * k_row_bytes,
+                    k_row_bytes);
+        }
+
+        const bool has_source_v = layer.v_stream.size() > source_strm && layer.v_stream[source_strm] != nullptr;
+        const bool has_dest_v = layer.v_stream.size() > dest_strm && layer.v_stream[dest_strm] != nullptr;
+        if (has_source_v != has_dest_v) {
+            error = "source and destination V stream layouts differ";
+            return false;
+        }
+        if (!has_source_v) {
+            continue;
+        }
+        auto * v_src = layer.v_stream[source_strm];
+        auto * v_dst = layer.v_stream[dest_strm];
+        const uint32_t n_embd_v_gqa = hparams.n_embd_v_gqa(layer.il);
+        if (!v_trans) {
+            const size_t v_row_bytes = ggml_row_size(v_src->type, n_embd_v_gqa);
+            if (v_row_bytes != ggml_row_size(v_dst->type, n_embd_v_gqa)) {
+                error = "source and destination V row layouts differ";
+                return false;
+            }
+            for (uint32_t i = 0; i < n_tokens; ++i) {
+                llama_kv_cache_copy_tensor_bytes_between(
+                        v_src,
+                        static_cast<size_t>(source_cell_idxs[i]) * v_row_bytes,
+                        v_dst,
+                        static_cast<size_t>(sinfo.idxs[0][i]) * v_row_bytes,
+                        v_row_bytes);
+            }
+        } else {
+            const size_t v_element_bytes = ggml_type_size(v_src->type);
+            if (v_element_bytes != ggml_type_size(v_dst->type)) {
+                error = "source and destination V element layouts differ";
+                return false;
+            }
+            for (uint32_t j = 0; j < n_embd_v_gqa; ++j) {
+                for (uint32_t i = 0; i < n_tokens; ++i) {
+                    llama_kv_cache_copy_tensor_bytes_between(
+                            v_src,
+                            (static_cast<size_t>(source_cell_idxs[i]) + static_cast<size_t>(j) * source_cells.size()) * v_element_bytes,
+                            v_dst,
+                            (static_cast<size_t>(sinfo.idxs[0][i]) + static_cast<size_t>(j) * dest_cells.size()) * v_element_bytes,
+                            v_element_bytes);
+                }
+            }
+        }
+    }
+
+    if (!copied_any_layer) {
+        error = "no KV cache layers were available for gathered path";
+        return false;
+    }
+    return true;
+}
+
 uint32_t llama_kv_cache::get_n_kv(const slot_info & sinfo) const {
     uint32_t result = 0;
 
