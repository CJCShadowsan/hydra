 }
 
+enum skippy_status skippy_session_overwrite_suffix(
+        struct skippy_session * session,
+        uint64_t token_count,
+        struct skippy_error ** out_error) {
+    return skippy_trim_session(session, token_count, out_error);
+}
+
+enum skippy_status skippy_session_gather_kv_path(
+        struct skippy_session * session,
+        int32_t source_seq_id,
+        uint64_t dest_start,
+        const uint64_t * source_positions,
+        size_t position_count,
+        const llama_token * token_ids,
+        size_t token_count,
+        struct skippy_error ** out_error) {
+    if (session == nullptr || session->ctx == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "session is required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (position_count == 0 || source_positions == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "source_positions and position_count are required");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (token_count > 0 && token_ids == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "token_ids are required when token_count is non-zero");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (token_count > 0 && token_count != position_count) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "token_count must match position_count");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (dest_start > static_cast<uint64_t>(std::numeric_limits<int32_t>::max()) ||
+            position_count > static_cast<size_t>(std::numeric_limits<int32_t>::max()) ||
+            dest_start + position_count < dest_start ||
+            dest_start + position_count > static_cast<uint64_t>(std::numeric_limits<int32_t>::max())) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "gather destination range exceeds int32_t session positions");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+    if (dest_start > static_cast<uint64_t>(session->n_past)) {
+        skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "cannot gather beyond current session position");
+        return SKIPPY_STATUS_INVALID_ARGUMENT;
+    }
+
+    session->ctx->synchronize();
+    llama_memory_t memory = session->ctx->get_memory();
+    if (memory == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "runtime memory is unavailable");
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+    auto * kv = dynamic_cast<llama_kv_cache *>(memory);
+    if (kv == nullptr) {
+        skippy_set_error(out_error, SKIPPY_STATUS_UNSUPPORTED, "tree KV gather is currently supported for dense KV cache memory only");
+        return SKIPPY_STATUS_UNSUPPORTED;
+    }
+
+    std::string error;
+    if (!kv->stage_gather_kv_path(
+                source_seq_id,
+                session->seq_id,
+                dest_start,
+                source_positions,
+                static_cast<uint64_t>(position_count),
+                error)) {
+        skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, error.c_str());
+        return SKIPPY_STATUS_RUNTIME_ERROR;
+    }
+
+    session->n_past = static_cast<int32_t>(dest_start + position_count);
+    if (session->token_history.size() > static_cast<size_t>(dest_start)) {
+        session->token_history.resize(static_cast<size_t>(dest_start));
+        skippy_clear_chat_sampling(session);
+    }
+    if (token_count > 0) {
+        session->token_history.insert(session->token_history.end(), token_ids, token_ids + token_count);
+        skippy_clear_chat_sampling(session);
+    }
+    if (session->signal_history.size() > static_cast<size_t>(dest_start)) {
+        session->signal_history.resize(static_cast<size_t>(dest_start));
+    }
+    session->checkpoint_valid = false;
+    session->checkpoint_n_past = 0;
+    session->checkpoint_token_history_size = 0;
+    session->checkpoint_signal_history_size = 0;
+    skippy_mtp_clear_session_state(session);
+    session->ctx->synchronize();
+
+    return skippy_success(out_error);
+}
