From 3f1588c0e4426b4556fa4084d2c09be8937818d1 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 11:19:13 +1000
Subject: [PATCH] Route GLM tensor traces through logger

---
 src/skippy.cpp | 46 +++++++++++++++++++++++-----------------------
 1 file changed, 23 insertions(+), 23 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index ff0b4b46c..8c34e3232 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -2048,18 +2048,18 @@ static bool skippy_glm_dsa_trace_filter_matches(const std::string & filter, cons
     return false;
 }
 
-static void skippy_glm_dsa_trace_tensor_values(const ggml_tensor * tensor, uint32_t limit) {
+static void skippy_glm_dsa_trace_tensor_values(std::string & line, const ggml_tensor * tensor, uint32_t limit) {
     const size_t value_count = static_cast<size_t>(
             std::min<int64_t>(static_cast<int64_t>(limit), std::max<int64_t>(0, ggml_nelements(tensor))));
 
-    std::fprintf(stderr, " values=[");
+    line += " values=[";
     if (value_count == 0) {
-        std::fprintf(stderr, "]");
+        line += "]";
         return;
     }
 
     if (!skippy_glm_dsa_tensor_has_buffer(tensor)) {
-        std::fprintf(stderr, "unallocated]");
+        line += "unallocated]";
         return;
     }
 
@@ -2068,7 +2068,7 @@ static void skippy_glm_dsa_trace_tensor_values(const ggml_tensor * tensor, uint3
             std::vector<float> values(value_count);
             ggml_backend_tensor_get(tensor, values.data(), 0, value_count * sizeof(float));
             for (size_t i = 0; i < value_count; ++i) {
-                std::fprintf(stderr, "%s%.9g", i == 0 ? "" : ",", static_cast<double>(values[i]));
+                line += format("%s%.9g", i == 0 ? "" : ",", static_cast<double>(values[i]));
             }
             break;
         }
@@ -2076,7 +2076,7 @@ static void skippy_glm_dsa_trace_tensor_values(const ggml_tensor * tensor, uint3
         case GGML_TYPE_BF16: {
             const ggml_type_traits * traits = ggml_get_type_traits(tensor->type);
             if (traits == nullptr || traits->to_float == nullptr) {
-                std::fprintf(stderr, "unsupported:%s", ggml_type_name(tensor->type));
+                line += format("unsupported:%s", ggml_type_name(tensor->type));
                 break;
             }
             std::vector<uint16_t> raw(value_count);
@@ -2084,7 +2084,7 @@ static void skippy_glm_dsa_trace_tensor_values(const ggml_tensor * tensor, uint3
             ggml_backend_tensor_get(tensor, raw.data(), 0, value_count * sizeof(uint16_t));
             traits->to_float(raw.data(), values.data(), value_count);
             for (size_t i = 0; i < value_count; ++i) {
-                std::fprintf(stderr, "%s%.9g", i == 0 ? "" : ",", static_cast<double>(values[i]));
+                line += format("%s%.9g", i == 0 ? "" : ",", static_cast<double>(values[i]));
             }
             break;
         }
@@ -2092,16 +2092,16 @@ static void skippy_glm_dsa_trace_tensor_values(const ggml_tensor * tensor, uint3
             std::vector<int32_t> values(value_count);
             ggml_backend_tensor_get(tensor, values.data(), 0, value_count * sizeof(int32_t));
             for (size_t i = 0; i < value_count; ++i) {
-                std::fprintf(stderr, "%s%d", i == 0 ? "" : ",", values[i]);
+                line += format("%s%d", i == 0 ? "" : ",", values[i]);
             }
             break;
         }
         default:
-            std::fprintf(stderr, "unsupported:%s", ggml_type_name(tensor->type));
+            line += format("unsupported:%s", ggml_type_name(tensor->type));
             break;
     }
 
-    std::fprintf(stderr, "]");
+    line += "]";
 }
 
 static uint64_t skippy_glm_dsa_fnv1a64(const uint8_t * data, size_t size) {
@@ -2113,7 +2113,7 @@ static uint64_t skippy_glm_dsa_fnv1a64(const uint8_t * data, size_t size) {
     return hash;
 }
 
-static void skippy_glm_dsa_trace_numeric_stats_from_f32(const float * values, size_t count) {
+static void skippy_glm_dsa_trace_numeric_stats_from_f32(std::string & line, const float * values, size_t count) {
     double sum = 0.0;
     double max_abs = 0.0;
     for (size_t i = 0; i < count; ++i) {
@@ -2122,7 +2122,7 @@ static void skippy_glm_dsa_trace_numeric_stats_from_f32(const float * values, si
         max_abs = std::max(max_abs, std::fabs(value));
     }
     const double mean = count == 0 ? 0.0 : sum / static_cast<double>(count);
-    std::fprintf(stderr,
+    line += format(
             " count=%zu sum=%.17g mean=%.17g max_abs=%.17g",
             count,
             sum,
@@ -2130,27 +2130,27 @@ static void skippy_glm_dsa_trace_numeric_stats_from_f32(const float * values, si
             max_abs);
 }
 
-static void skippy_glm_dsa_trace_tensor_stats(const ggml_tensor * tensor, uint32_t max_bytes) {
+static void skippy_glm_dsa_trace_tensor_stats(std::string & line, const ggml_tensor * tensor, uint32_t max_bytes) {
     if (!skippy_glm_dsa_tensor_has_buffer(tensor)) {
-        std::fprintf(stderr, " stats=unallocated");
+        line += " stats=unallocated";
         return;
     }
 
     const size_t nbytes = ggml_nbytes(tensor);
     if (nbytes > static_cast<size_t>(max_bytes)) {
-        std::fprintf(stderr, " stats=skipped:nbytes>%u", max_bytes);
+        line += format(" stats=skipped:nbytes>%u", max_bytes);
         return;
     }
 
     std::vector<uint8_t> raw(nbytes);
     ggml_backend_tensor_get(tensor, raw.data(), 0, nbytes);
     const uint64_t hash = skippy_glm_dsa_fnv1a64(raw.data(), raw.size());
-    std::fprintf(stderr, " stats=fnv64:%016llx", static_cast<unsigned long long>(hash));
+    line += format(" stats=fnv64:%016llx", static_cast<unsigned long long>(hash));
 
     const size_t count = static_cast<size_t>(std::max<int64_t>(0, ggml_nelements(tensor)));
     switch (tensor->type) {
         case GGML_TYPE_F32:
-            skippy_glm_dsa_trace_numeric_stats_from_f32(reinterpret_cast<const float *>(raw.data()), count);
+            skippy_glm_dsa_trace_numeric_stats_from_f32(line, reinterpret_cast<const float *>(raw.data()), count);
             break;
         case GGML_TYPE_F16:
         case GGML_TYPE_BF16: {
@@ -2160,7 +2160,7 @@ static void skippy_glm_dsa_trace_tensor_stats(const ggml_tensor * tensor, uint32
             }
             std::vector<float> values(count);
             traits->to_float(raw.data(), values.data(), count);
-            skippy_glm_dsa_trace_numeric_stats_from_f32(values.data(), count);
+            skippy_glm_dsa_trace_numeric_stats_from_f32(line, values.data(), count);
             break;
         }
         case GGML_TYPE_I32: {
@@ -2173,7 +2173,7 @@ static void skippy_glm_dsa_trace_tensor_stats(const ggml_tensor * tensor, uint32
                 max_abs = std::max(max_abs, std::fabs(value));
             }
             const double mean = count == 0 ? 0.0 : sum / static_cast<double>(count);
-            std::fprintf(stderr,
+            line += format(
                     " count=%zu sum=%.17g mean=%.17g max_abs=%.17g",
                     count,
                     sum,
@@ -2197,7 +2197,7 @@ static void skippy_glm_dsa_trace_tensor(
     }
 
     timing.trace_nodes += 1;
-    std::fprintf(stderr,
+    std::string line = format(
             "skippy: glm_dsa_tensor_trace stage=%d tokens=%zu op=%s node=%u name=%s type=%s ne=[%lld,%lld,%lld,%lld] nb=[%zu,%zu,%zu,%zu] contiguous=%d nbytes=%zu",
             timing.stage_index,
             timing.token_count,
@@ -2215,11 +2215,11 @@ static void skippy_glm_dsa_trace_tensor(
             static_cast<size_t>(tensor->nb[3]),
             ggml_is_contiguous(tensor) ? 1 : 0,
             ggml_nbytes(tensor));
-    skippy_glm_dsa_trace_tensor_values(tensor, timing.trace_value_limit);
+    skippy_glm_dsa_trace_tensor_values(line, tensor, timing.trace_value_limit);
     if (timing.trace_stats) {
-        skippy_glm_dsa_trace_tensor_stats(tensor, timing.trace_stats_max_bytes);
+        skippy_glm_dsa_trace_tensor_stats(line, tensor, timing.trace_stats_max_bytes);
     }
-    std::fprintf(stderr, "\n");
+    LLAMA_LOG_INFO("%s\n", line.c_str());
 }
 
 static bool skippy_glm_dsa_op_timing_cb(ggml_tensor * tensor, bool ask, void * user_data) {
-- 
2.53.0

