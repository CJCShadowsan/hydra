From aedcfdd1b9f5596bb8c83d8fada88f7d40ce3e4e Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 17:48:22 +1000
Subject: [PATCH] Allow GLM DSA chunked prefill and decode sidebands

---
 src/skippy.cpp | 15 +++++++++++++--
 1 file changed, 13 insertions(+), 2 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index bb236814e..f876437fe 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1334,13 +1334,24 @@ static bool skippy_glm_dsa_sideband_top_k_count_is_valid(
         size_t token_count,
         uint32_t actual_top_k,
         uint32_t expected_top_k) {
-    GGML_UNUSED(token_count);
-
     if (actual_top_k == 0 || expected_top_k == 0) {
         return false;
     }
 
-    return actual_top_k == expected_top_k;
+    // Prefill sidebands can be chunk-local: llama.cpp emits the actual
+    // per-chunk top-k width, while the receiving staged session may have a
+    // larger accumulated KV prefix.
+    if (token_count > 1) {
+        return actual_top_k <= expected_top_k;
+    }
+
+    // Decode producers export the actual top-k tensor width from their graph.
+    // That can be one token behind the receiving session's accumulated
+    // n_past + token_count expectation because the downstream side validates
+    // after accounting for the current decode token.
+    const uint64_t actual_plus_token_count =
+            static_cast<uint64_t>(actual_top_k) + static_cast<uint64_t>(token_count);
+    return actual_top_k == expected_top_k || actual_plus_token_count == expected_top_k;
 }
 
 static size_t skippy_glm_dsa_top_k_bytes(const skippy_session * session, size_t token_count) {
