From 80816795f1dd695b7b5a2aa69ce4a90803743da2 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Wed, 17 Jun 2026 20:49:30 +1000
Subject: [PATCH] Break down VerifySpan MTP sync timing

---
 src/skippy.cpp | 55 +++++++++++++++++++++++++++++++++++++++++++++-----
 1 file changed, 50 insertions(+), 5 deletions(-)

diff --git a/src/skippy.cpp b/src/skippy.cpp
index 7b4774f0..6deaac81 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1278,6 +1278,14 @@ static bool skippy_verify_span_native_timing_enabled() {
 struct skippy_verify_span_native_timing {
     int64_t target_decode_us = 0;
     int64_t mtp_sync_us = 0;
+    int64_t mtp_sync_calls = 0;
+    int64_t mtp_sync_decoded_tokens = 0;
+    int64_t mtp_sync_pending_draft_accepts = 0;
+    int64_t mtp_sync_pending_draft_rejects = 0;
+    int64_t mtp_sync_draft_us = 0;
+    int64_t mtp_sync_setup_us = 0;
+    int64_t mtp_sync_decode_us = 0;
+    int64_t mtp_sync_pending_h_copy_us = 0;
     int64_t output_copy_us = 0;
     int64_t sampling_us = 0;
     int64_t proposal_total_us = 0;
@@ -1306,6 +1314,7 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
         const llama_token * token_ids,
         size_t token_count,
         llama_pos token_start,
+        skippy_verify_span_native_timing * timing,
         struct skippy_error ** out_error) {
     if (!skippy_mtp_available(session) || token_ids == nullptr || token_count == 0) {
         return skippy_success(out_error);
@@ -1314,6 +1323,9 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
         skippy_set_error(out_error, SKIPPY_STATUS_INVALID_ARGUMENT, "MTP token_count exceeds int32_t range");
         return SKIPPY_STATUS_INVALID_ARGUMENT;
     }
+    if (timing != nullptr) {
+        timing->mtp_sync_calls += 1;
+    }
 
     llama_context * mtp_ctx = session->stage_model->mtp_ctx;
     const int32_t n_embd = llama_model_n_embd(session->stage_model->model);
@@ -1323,6 +1335,7 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
         session->mtp_has_pending_h = false;
     }
 
+    const int64_t draft_start_us = timing != nullptr ? ggml_time_us() : 0;
     if (session->mtp_has_pending_draft) {
         const llama_pos token_end = token_start + static_cast<llama_pos>(token_count);
         if (session->mtp_pending_draft_pos >= token_start &&
@@ -1330,17 +1343,26 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
             const size_t draft_index = static_cast<size_t>(session->mtp_pending_draft_pos - token_start);
             if (token_ids[draft_index] == session->mtp_pending_draft_token) {
                 session->mtp_next_pos = std::max(session->mtp_next_pos, session->mtp_pending_draft_pos + 1);
+                if (timing != nullptr) {
+                    timing->mtp_sync_pending_draft_accepts += 1;
+                }
             } else {
                 if (llama_memory_t memory = mtp_ctx->get_memory()) {
                     llama_memory_seq_rm(memory, session->seq_id, session->mtp_pending_draft_pos, -1);
                 }
                 session->mtp_next_pos = std::min(session->mtp_next_pos, static_cast<int32_t>(session->mtp_pending_draft_pos));
+                if (timing != nullptr) {
+                    timing->mtp_sync_pending_draft_rejects += 1;
+                }
             }
         }
         session->mtp_has_pending_draft = false;
         session->mtp_pending_draft_pos = 0;
         session->mtp_pending_draft_token = -1;
     }
+    if (timing != nullptr) {
+        timing->mtp_sync_draft_us += ggml_time_us() - draft_start_us;
+    }
 
     size_t first_index = 0;
     if (session->mtp_next_pos > token_start) {
@@ -1350,7 +1372,11 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
     }
 
     const int32_t n_decode = static_cast<int32_t>(token_count - first_index);
+    if (timing != nullptr) {
+        timing->mtp_sync_decoded_tokens += n_decode;
+    }
     if (n_decode > 0) {
+        const int64_t setup_start_us = timing != nullptr ? ggml_time_us() : 0;
         llama_batch batch = llama_batch_init(n_decode, n_embd, 1);
         batch.token = static_cast<llama_token *>(std::malloc(sizeof(llama_token)*static_cast<size_t>(n_decode)));
         if (batch.token == nullptr) {
@@ -1383,9 +1409,16 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
                 std::memcpy(dst, h_prev, row_bytes);
             }
         }
+        if (timing != nullptr) {
+            timing->mtp_sync_setup_us += ggml_time_us() - setup_start_us;
+        }
 
         skippy_graph_filter_scope graph_filter_scope(&session->stage_model->config);
+        const int64_t decode_start_us = timing != nullptr ? ggml_time_us() : 0;
         const int32_t rc = llama_decode(mtp_ctx, batch);
+        if (timing != nullptr) {
+            timing->mtp_sync_decode_us += ggml_time_us() - decode_start_us;
+        }
         std::free(batch.token);
         batch.token = nullptr;
         llama_batch_free(batch);
@@ -1401,7 +1434,11 @@ static enum skippy_status skippy_mtp_sync_target_tokens(
         skippy_set_error(out_error, SKIPPY_STATUS_RUNTIME_ERROR, "target pre-norm hidden row was not available");
         return SKIPPY_STATUS_RUNTIME_ERROR;
     }
+    const int64_t pending_h_copy_start_us = timing != nullptr ? ggml_time_us() : 0;
     std::memcpy(session->mtp_pending_h.data(), h_last, row_bytes);
+    if (timing != nullptr) {
+        timing->mtp_sync_pending_h_copy_us += ggml_time_us() - pending_h_copy_start_us;
+    }
     session->mtp_has_pending_h = true;
     return skippy_success(out_error);
 }
@@ -1457,7 +1494,7 @@ static enum skippy_status skippy_decode_tokens(
         };
         enum skippy_status status = skippy_decode_batch(session, batch, 1, out_error);
         if (status == SKIPPY_STATUS_OK) {
-            status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, pos, out_error);
+            status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, pos, nullptr, out_error);
         }
         if (status == SKIPPY_STATUS_OK) {
             skippy_record_tokens(session, token_ids, token_count);
@@ -1479,7 +1516,7 @@ static enum skippy_status skippy_decode_tokens(
     enum skippy_status status = skippy_decode_batch(session, batch, token_count, out_error);
     llama_batch_free(batch);
     if (status == SKIPPY_STATUS_OK) {
-        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, out_error);
+        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, nullptr, out_error);
     }
     if (status == SKIPPY_STATUS_OK) {
         skippy_record_tokens(session, token_ids, token_count);
@@ -2282,7 +2319,7 @@ static enum skippy_status skippy_decode_activation_frame(
     const llama_pos token_start = pos_storage.empty() ? session->n_past : pos_storage[0];
     enum skippy_status status = skippy_decode_batch(session, batch, token_count, out_error);
     if (status == SKIPPY_STATUS_OK && token_ids != nullptr) {
-        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, out_error);
+        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, nullptr, out_error);
     }
     return status;
 }
@@ -2357,7 +2394,7 @@ static enum skippy_status skippy_verify_activation_frame(
     }
     if (status == SKIPPY_STATUS_OK && token_ids != nullptr) {
         const int64_t sync_start_us = timing != nullptr ? ggml_time_us() : 0;
-        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, out_error);
+        status = skippy_mtp_sync_target_tokens(session, token_ids, token_count, token_start, timing, out_error);
         if (timing != nullptr) {
             timing->mtp_sync_us += ggml_time_us() - sync_start_us;
         }
@@ -4018,12 +4055,20 @@ enum skippy_status skippy_verify_tokens_frame_sampled(
 
     if (native_timing_ptr != nullptr) {
         fprintf(stderr,
-                "skippy_verify_span_native_timing stage=%d seq=%d tokens=%zu target_decode_us=%lld mtp_sync_us=%lld output_copy_us=%lld sampling_us=%lld proposal_total_us=%lld proposal_decode_us=%lld\n",
+                "skippy_verify_span_native_timing stage=%d seq=%d tokens=%zu target_decode_us=%lld mtp_sync_us=%lld mtp_sync_calls=%lld mtp_sync_decoded_tokens=%lld mtp_sync_pending_draft_accepts=%lld mtp_sync_pending_draft_rejects=%lld mtp_sync_draft_us=%lld mtp_sync_setup_us=%lld mtp_sync_decode_us=%lld mtp_sync_pending_h_copy_us=%lld output_copy_us=%lld sampling_us=%lld proposal_total_us=%lld proposal_decode_us=%lld\n",
                 session->stage_model->config.stage_index,
                 session->seq_id,
                 token_count,
                 (long long) native_timing.target_decode_us,
                 (long long) native_timing.mtp_sync_us,
+                (long long) native_timing.mtp_sync_calls,
+                (long long) native_timing.mtp_sync_decoded_tokens,
+                (long long) native_timing.mtp_sync_pending_draft_accepts,
+                (long long) native_timing.mtp_sync_pending_draft_rejects,
+                (long long) native_timing.mtp_sync_draft_us,
+                (long long) native_timing.mtp_sync_setup_us,
+                (long long) native_timing.mtp_sync_decode_us,
+                (long long) native_timing.mtp_sync_pending_h_copy_us,
                 (long long) native_timing.output_copy_us,
                 (long long) native_timing.sampling_us,
                 (long long) native_timing.proposal_total_us,
-- 
2.54.0 (Apple Git-156)

