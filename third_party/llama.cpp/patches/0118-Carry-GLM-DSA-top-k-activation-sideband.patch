diff --git a/src/skippy.cpp b/src/skippy.cpp
index 20c41eec..6cda9f04 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1044,6 +1044,35 @@ struct skippy_gemma3n_altup_scope {
