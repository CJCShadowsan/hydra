From 7be8fa0436b4500c03ab0d43c7cf006d82792620 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 10:15:36 +1000
Subject: [PATCH] Guard GLM MoE route graph packing

---
 ggml/src/ggml-metal/ggml-metal-common.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/ggml/src/ggml-metal/ggml-metal-common.cpp b/ggml/src/ggml-metal/ggml-metal-common.cpp
index e355d5066..c8dec0508 100644
--- a/ggml/src/ggml-metal/ggml-metal-common.cpp
+++ b/ggml/src/ggml-metal/ggml-metal-common.cpp
@@ -213,6 +213,11 @@ static bool ggml_metal_topk_moe_route_fusion_enabled() {
     return value && atoi(value) != 0;
 }
 
+static bool ggml_metal_topk_moe_route_pack_enabled() {
+    const char * value = getenv("SKIPPY_GLM_DSA_ENABLE_METAL_TOPK_MOE_ROUTE_PACK");
+    return value && atoi(value) != 0;
+}
+
 static bool ggml_metal_dispatch_log_enabled() {
     const char * value = getenv("SKIPPY_GLM_DSA_LOG_METAL_DISPATCH");
     return value && atoi(value) != 0;
@@ -253,7 +258,7 @@ static void ggml_metal_log_topk_moe_route_candidate(const ggml_cgraph * gf, int
 }
 
 static int ggml_metal_topk_moe_route_pack_len(const ggml_cgraph * gf, int i) {
-    if (!ggml_metal_topk_moe_route_fusion_enabled() || i + 11 > gf->n_nodes) {
+    if (!ggml_metal_topk_moe_route_fusion_enabled() || !ggml_metal_topk_moe_route_pack_enabled() || i + 11 > gf->n_nodes) {
         return 1;
     }
 
