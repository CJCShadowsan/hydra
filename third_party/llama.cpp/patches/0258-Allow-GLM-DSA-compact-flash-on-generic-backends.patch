From 5e914550d971f3ad442e6c5a2837e55c88050151 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 21:03:16 +1000
Subject: [PATCH] Allow GLM DSA compact flash on generic backends

---
 src/llama-graph.cpp | 64 ++++++++++++++++++++++++++++++++++++++-------
 1 file changed, 55 insertions(+), 9 deletions(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 86a62d6ed..d27648af2 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -252,6 +252,20 @@ static bool llama_glm_dsa_backend_supports_native_sparse(int backend_device_type
     return false;
 }
 
+static bool llama_glm_dsa_backend_supports_compact_flash(int backend_device_type) {
+    switch (backend_device_type) {
+        case GGML_BACKEND_DEVICE_TYPE_CPU:
+        case GGML_BACKEND_DEVICE_TYPE_GPU:
+        case GGML_BACKEND_DEVICE_TYPE_IGPU:
+        case GGML_BACKEND_DEVICE_TYPE_ACCEL:
+            return true;
+        case GGML_BACKEND_DEVICE_TYPE_META:
+            return false;
+    }
+
+    return false;
+}
+
 static bool llama_glm_dsa_layer_backend_supports_native_sparse(
         const std::vector<int> & layer_backend_device_types,
         int il) {
@@ -262,6 +276,16 @@ static bool llama_glm_dsa_layer_backend_supports_native_sparse(
     return llama_glm_dsa_backend_supports_native_sparse(layer_backend_device_types[il]);
 }
 
+static bool llama_glm_dsa_layer_backend_supports_compact_flash(
+        const std::vector<int> & layer_backend_device_types,
+        int il) {
+    if (il < 0 || (size_t) il >= layer_backend_device_types.size()) {
+        return false;
+    }
+
+    return llama_glm_dsa_backend_supports_compact_flash(layer_backend_device_types[il]);
+}
+
 static bool llama_glm_dsa_all_layer_backends_support_native_sparse(
         const std::vector<int> & layer_backend_device_types) {
     if (layer_backend_device_types.empty()) {
@@ -277,6 +301,21 @@ static bool llama_glm_dsa_all_layer_backends_support_native_sparse(
     return true;
 }
 
+static bool llama_glm_dsa_all_layer_backends_support_compact_flash(
+        const std::vector<int> & layer_backend_device_types) {
+    if (layer_backend_device_types.empty()) {
+        return false;
+    }
+
+    for (int backend_device_type : layer_backend_device_types) {
+        if (!llama_glm_dsa_backend_supports_compact_flash(backend_device_type)) {
+            return false;
+        }
+    }
+
+    return true;
+}
+
 struct llama_glm_dsa_sparse_attn_policy {
     llama_glm_dsa_sparse_attn_route route = llama_glm_dsa_sparse_attn_route::DENSE_MASK;
     const char * phase = "other";
@@ -299,6 +338,7 @@ struct llama_glm_dsa_sparse_attn_policy {
     bool compact_kv_ok = false;
     bool compact_candidate = false;
     bool backend_sparse_supported = false;
+    bool backend_compact_supported = false;
     bool flash_attn = false;
     int64_t direct_sparse_decode_max_top_k = 0;
     int64_t compact_flash_min_kv = 0;
@@ -343,6 +383,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
         bool    unproven_large_direct_sparse_prefill_enabled,
         bool    flash_attn,
         bool    backend_sparse_supported,
+        bool    backend_compact_supported,
         bool    compact_flash_disabled,
         bool    compact_mask_omitted,
         bool    kq_b_ok,
@@ -359,6 +400,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
     policy.compact_disabled = compact_flash_disabled;
     policy.compact_mask_omitted = compact_mask_omitted;
     policy.backend_sparse_supported = backend_sparse_supported;
+    policy.backend_compact_supported = backend_compact_supported;
     policy.flash_attn = flash_attn;
     policy.direct_sparse_decode_max_top_k = skippy_glm_dsa_direct_sparse_decode_max_top_k();
     policy.compact_flash_min_kv = skippy_glm_dsa_compact_flash_min_kv();
@@ -403,7 +445,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
             (policy.compact_large_decode_top_k || compact_mask_omitted);
     const bool compact_ready =
             policy.compact_candidate &&
-            backend_sparse_supported &&
+            backend_compact_supported &&
             flash_attn &&
             kq_b_ok &&
             sinks_ok &&
@@ -452,7 +494,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
 
     policy.compact_selector_reason =
             compact_flash_disabled ? "disabled" :
-            !backend_sparse_supported ? "backend_sparse_unsupported" :
+            !backend_compact_supported ? "backend_compact_unsupported" :
             !flash_attn ? "flash_attn_disabled" :
             !policy.decode_shape ? "not_decode" :
             !policy.compact_kv_ok ? "kv_below_min" :
@@ -471,7 +513,7 @@ static bool llama_glm_dsa_can_skip_mla_kq_mask_for_compact_decode(
         const llama_cparams & cparams,
         const llama_ubatch  & ubatch,
         const llama_kv_cache_context * mctx_mla,
-        bool backend_sparse_supported,
+        bool backend_compact_supported,
         bool eligible) {
     if (!eligible || mctx_mla == nullptr) {
         return false;
@@ -505,7 +547,8 @@ static bool llama_glm_dsa_can_skip_mla_kq_mask_for_compact_decode(
             skippy_glm_dsa_direct_sparse_prefill_enabled(),
             skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled(),
             cparams.flash_attn,
-            backend_sparse_supported,
+            false,
+            backend_compact_supported,
             skippy_glm_dsa_compact_flash_attn_disabled(),
             false,
             true,
@@ -626,7 +669,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
         bool    large_decode_top_k,
         bool    kv_ok,
         bool    enabled,
-        bool    backend_sparse_supported,
+        bool    backend_compact_supported,
         bool    flash_attn,
         bool    decode_shape,
         bool    no_mask,
@@ -641,7 +684,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
     }
 
     LLAMA_LOG_INFO(
-            "skippy: glm_dsa_compact_flash_policy layer=%d ubatch_tokens=%lld visible_kv=%lld top_k=%lld decode_max_top_k=%lld compact_min_kv=%lld kv_topk_ratio=%lld forced=%d disabled=%d large_decode_top_k=%d kv_ok=%d enabled=%d backend_sparse_supported=%d flash_attn=%d phase=%s decode_shape=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d no_mask=%d use_compact=%d selector_reason=%s\n",
+            "skippy: glm_dsa_compact_flash_policy layer=%d ubatch_tokens=%lld visible_kv=%lld top_k=%lld decode_max_top_k=%lld compact_min_kv=%lld kv_topk_ratio=%lld forced=%d disabled=%d large_decode_top_k=%d kv_ok=%d enabled=%d backend_compact_supported=%d flash_attn=%d phase=%s decode_shape=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d no_mask=%d use_compact=%d selector_reason=%s\n",
             layer,
             (long long) ubatch_tokens,
             (long long) visible_kv,
@@ -654,7 +697,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
             large_decode_top_k ? 1 : 0,
             kv_ok ? 1 : 0,
             enabled ? 1 : 0,
-            backend_sparse_supported ? 1 : 0,
+            backend_compact_supported ? 1 : 0,
             flash_attn ? 1 : 0,
             decode_shape ? "decode" : "other",
             decode_shape ? 1 : 0,
@@ -3681,6 +3724,8 @@ ggml_tensor * llm_graph_context::build_attn(
     const bool direct_sparse_soft_cap_ok = !hparams.attn_soft_cap;
     const bool backend_sparse_supported =
             llama_glm_dsa_layer_backend_supports_native_sparse(layer_backend_device_types, il);
+    const bool backend_compact_supported =
+            llama_glm_dsa_layer_backend_supports_compact_flash(layer_backend_device_types, il);
     const bool verification_batch = llama_glm_dsa_verification_batch_shape(
             ubatch,
             n_direct_sparse_batch,
@@ -3700,6 +3745,7 @@ ggml_tensor * llm_graph_context::build_attn(
             skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled(),
             cparams.flash_attn,
             backend_sparse_supported,
+            backend_compact_supported,
             skippy_glm_dsa_compact_flash_attn_disabled(),
             kq_mask == nullptr,
             direct_sparse_kq_b_ok,
@@ -3745,7 +3791,7 @@ ggml_tensor * llm_graph_context::build_attn(
             sparse_policy.compact_large_decode_top_k,
             sparse_policy.compact_kv_ok,
             sparse_policy.compact_candidate,
-            sparse_policy.backend_sparse_supported,
+            sparse_policy.backend_compact_supported,
             sparse_policy.flash_attn,
             sparse_policy.decode_shape,
             kq_mask == nullptr,
@@ -3991,7 +4037,7 @@ llm_graph_input_attn_k_dsa * llm_graph_context::build_attn_inp_k_dsa() const {
             cparams,
             ubatch,
             mctx_cur->get_mla(),
-            llama_glm_dsa_all_layer_backends_support_native_sparse(layer_backend_device_types),
+            llama_glm_dsa_all_layer_backends_support_compact_flash(layer_backend_device_types),
             inp->glm_dsa_compact_decode_mask_eligible);
 
     {
-- 
2.53.0

