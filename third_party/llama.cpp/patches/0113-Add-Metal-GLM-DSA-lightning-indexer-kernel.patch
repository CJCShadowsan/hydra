+                   op->src[0]->nb[0] == sizeof(float) &&
+                   op->src[1]->nb[0] == ggml_type_size(op->src[1]->type) &&
+                   op->src[2]->nb[0] == sizeof(float) &&
+                   op->src[0]->ne[0] == op->src[1]->ne[0] &&
