+                   op->src[0]->ne[2] == op->src[2]->ne[1] &&
+                   op->src[2]->ne[2] == 1 &&
+                   op->src[0]->ne[3] == op->src[1]->ne[3] &&
+                   op->src[1]->ne[3] == op->src[2]->ne[3];
         case GGML_OP_SOLVE_TRI:
         case GGML_OP_MUL_MAT:
