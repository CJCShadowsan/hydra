From ed341fd7d4e387df8bd49cd2536060479b0bf361 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Sat, 4 Jul 2026 11:51:32 +1000
Subject: [PATCH 240/240] Measure GLM DSA weighted down MoE path

---
 scripts/glm52-phase-e-moe-report.sh |  4 ++++
 tests/test-backend-ops.cpp          | 18 +++++++++++++++---
 2 files changed, 19 insertions(+), 3 deletions(-)

diff --git a/scripts/glm52-phase-e-moe-report.sh b/scripts/glm52-phase-e-moe-report.sh
index c141a23a7..f4bb2422f 100755
--- a/scripts/glm52-phase-e-moe-report.sh
+++ b/scripts/glm52-phase-e-moe-report.sh
@@ -109,6 +109,7 @@ route = find("TOPK_MOE_GLM_ROUTE")
 weighted_1 = find("MOE_WEIGHTED_SUM", "n_tokens=1")
 weighted_4 = find("MOE_WEIGHTED_SUM", "n_tokens=4")
 consumer_q = find("TOPK_MOE_GLM_CONSUMER", "gate_type=q2_K")
+consumer_q_weighted = find("TOPK_MOE_GLM_CONSUMER", "weighted_down=1")
 gate_up = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=2048,n=1,k=6144")
 merged_gate_up = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=4096,n=1,k=6144")
 down_q2 = find("MUL_MAT_ID", "type_a=q2_K,type_b=f32,n_mats=256,n_used=8,b=0,m=6144,n=1,k=2048")
@@ -143,6 +144,7 @@ add_row("Route/top-k + weights", route)
 add_row("Weighted sum, 1 token", weighted_1)
 add_row("Weighted sum, 4 tokens", weighted_4)
 add_row("Small quantized whole-graph consumer", consumer_q)
+add_row("Small quantized whole-graph consumer, weighted down", consumer_q_weighted)
 add_row("Routed gate/up matmul", gate_up)
 add_row("Merged routed gate+up matmul", merged_gate_up)
 add_row("Routed down matmul, q2_K alternative", down_q2)
@@ -165,6 +167,8 @@ if estimated_decode is not None:
     if down_q2:
         q2_down_cost = 2.0 * gate_up["us"] + down_q2["us"] + overhead
         lines.append(f"- q2_K down estimate: `{q2_down_cost:.2f} us` ({estimated_decode / q2_down_cost:.2f}x faster than current estimate, quality tradeoff not measured here).")
+    if consumer_q and consumer_q_weighted:
+        lines.append(f"- Small weighted-down whole-graph fixture: `{consumer_q_weighted['us']:.2f} us` ({consumer_q['us'] / consumer_q_weighted['us']:.2f}x faster than baseline).")
 else:
     lines.append("- Missing rows prevented the per-layer estimate.")
 
diff --git a/tests/test-backend-ops.cpp b/tests/test-backend-ops.cpp
index 9339cb050..66ba25d9c 100644
--- a/tests/test-backend-ops.cpp
+++ b/tests/test-backend-ops.cpp
@@ -6149,6 +6149,7 @@ struct test_topk_moe_glm_consumer : public test_case {
     const ggml_type down_type;
     const int64_t n_embd;
     const int64_t n_ff;
+    const bool weighted_down;
 
     ggml_tensor * selected_experts = nullptr;
     ggml_tensor * weights = nullptr;
@@ -6162,19 +6163,21 @@ struct test_topk_moe_glm_consumer : public test_case {
             ggml_type up_type   = GGML_TYPE_F32,
             ggml_type down_type = GGML_TYPE_F32,
             int64_t   n_embd    = 64,
-            int64_t   n_ff      = 128)
+            int64_t   n_ff      = 128,
+            bool      weighted_down = false)
         : gate_type(gate_type),
           up_type(up_type),
           down_type(down_type),
           n_embd(n_embd),
-          n_ff(n_ff) {
+          n_ff(n_ff),
+          weighted_down(weighted_down) {
         GGML_ASSERT(n_embd % ggml_blck_size(gate_type) == 0);
         GGML_ASSERT(n_embd % ggml_blck_size(up_type) == 0);
         GGML_ASSERT(n_ff   % ggml_blck_size(down_type) == 0);
     }
 
     std::string vars() override {
-        return VARS_TO_STR8(gate_type, up_type, down_type, n_expert, n_expert_used, n_tokens, n_embd, n_ff);
+        return VARS_TO_STR9(gate_type, up_type, down_type, n_expert, n_expert_used, n_tokens, n_embd, n_ff, weighted_down);
     }
 
     std::string op_desc(ggml_tensor * t) override {
@@ -6259,10 +6262,18 @@ struct test_topk_moe_glm_consumer : public test_case {
         ffn_act = ggml_mul(ctx, ffn_act, ffn_up);
         ggml_set_name(ffn_act, "ffn_moe_gate_up");
 
+        if (weighted_down) {
+            ffn_act = ggml_mul(ctx, ffn_act, weights);
+            ggml_set_name(ffn_act, "ffn_moe_down_weighted_input");
+        }
+
         ffn_down = ggml_mul_mat_id(ctx, downs, ffn_act, selected_experts);
         ggml_set_name(ffn_down, "ffn_moe_down");
 
         out = ggml_moe_weighted_sum(ctx, ffn_down, weights);
+        if (weighted_down) {
+            out->op_params[0] = 1;
+        }
         ggml_set_name(out, "ffn_moe_out");
 
         return out;
@@ -10435,6 +10446,7 @@ static std::vector<std::unique_ptr<test_case>> make_test_cases_perf() {
     test_cases.emplace_back(new test_moe_weighted_sum(6144, 8, 4));
     test_cases.emplace_back(new test_topk_moe_glm_consumer());
     test_cases.emplace_back(new test_topk_moe_glm_consumer(GGML_TYPE_Q2_K, GGML_TYPE_Q2_K, GGML_TYPE_Q3_K, 256, 256));
+    test_cases.emplace_back(new test_topk_moe_glm_consumer(GGML_TYPE_Q2_K, GGML_TYPE_Q2_K, GGML_TYPE_Q3_K, 256, 256, true));
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q2_K, GGML_TYPE_F32, 256, 8, false, 2048, 1, 6144));
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q2_K, GGML_TYPE_F32, 256, 8, false, 4096, 1, 6144));
     test_cases.emplace_back(new test_mul_mat_id(GGML_TYPE_Q2_K, GGML_TYPE_F32, 256, 8, false, 6144, 1, 2048));
-- 
2.53.0

