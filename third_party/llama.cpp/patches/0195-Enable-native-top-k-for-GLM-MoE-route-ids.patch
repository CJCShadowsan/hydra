From 73876c615446bcbeecfdb38a45f27532df2120ab Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 13:20:53 +1000
Subject: [PATCH] Enable native top-k for GLM MoE route ids

---
 src/llama-graph.cpp | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index f06afd6c7..fa755985d 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -115,7 +115,12 @@ static bool skippy_glm_dsa_moe_route_weights_enabled() {
 }
 
 static bool skippy_glm_dsa_moe_top_k_enabled() {
-    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_MOE_TOP_K");
+    if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_MOE_TOP_K") ||
+        skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_MOE_TOP_K")) {
+        return false;
+    }
+
+    return true;
 }
 
 static ggml_tensor * llama_glm_dsa_top_k_for_sparse_attn(ggml_context * ctx, ggml_tensor * top_k) {
