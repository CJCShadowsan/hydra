             layer,
             (long long) ubatch_tokens,
             (long long) visible_kv,
@@ -603,6 +654,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
             large_decode_top_k ? 1 : 0,
             kv_ok ? 1 : 0,
