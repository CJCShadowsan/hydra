 ggml/src/ggml-metal/ggml-metal-device.h   |   2 +-
 ggml/src/ggml-metal/ggml-metal-ops.cpp    |  37 +++++-
 ggml/src/ggml-metal/ggml-metal.metal      | 144 ++++++++++++++++++++++
