From 6ff766d81d67773f37509e0bf72b5ed5aac0b7c3 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 11:28:53 +1000
Subject: [PATCH] Keep GLM compact decode mask omission on compact path

---
 src/llama-graph.cpp | 21 +++++++++++++++++----
 1 file changed, 17 insertions(+), 4 deletions(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 790c84cbe..c85fbb1a8 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -150,6 +150,7 @@ struct llama_glm_dsa_sparse_attn_policy {
     bool soft_cap_ok = false;
     bool compact_disabled = false;
     bool compact_large_decode_top_k = false;
+    bool compact_mask_omitted = false;
     bool compact_candidate = false;
     bool flash_attn = false;
 
@@ -177,6 +178,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
         bool    unproven_large_direct_sparse_prefill_enabled,
         bool    flash_attn,
         bool    compact_flash_disabled,
+        bool    compact_mask_omitted,
         bool    kq_b_ok,
         bool    sinks_ok,
         bool    alibi_ok,
@@ -189,6 +191,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
     policy.alibi_ok = alibi_ok;
     policy.soft_cap_ok = soft_cap_ok;
     policy.compact_disabled = compact_flash_disabled;
+    policy.compact_mask_omitted = compact_mask_omitted;
     policy.flash_attn = flash_attn;
 
     policy.decode_shape =
@@ -217,7 +220,8 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
             sparse_top_k > LLAMA_GLM_DSA_DIRECT_SPARSE_DECODE_MAX_TOP_K;
     policy.compact_candidate =
             !compact_flash_disabled &&
-            policy.compact_large_decode_top_k;
+            policy.decode_shape &&
+            (policy.compact_large_decode_top_k || compact_mask_omitted);
     const bool compact_ready =
             policy.compact_candidate &&
             flash_attn &&
@@ -228,7 +232,9 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
     if (compact_ready) {
         policy.route = llama_glm_dsa_sparse_attn_route::COMPACT_FLASH;
         policy.direct_selector_reason = "compact_flash_selected";
-        policy.compact_selector_reason = "decode_compact_large_top_k";
+        policy.compact_selector_reason =
+                compact_mask_omitted ? "decode_compact_mask_omitted" :
+                "decode_compact_large_top_k";
         return policy;
     }
 
@@ -236,6 +242,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
             direct_sparse_enabled &&
             policy.token_shape_allowed &&
             !policy.compact_large_decode_top_k &&
+            !compact_mask_omitted &&
             kq_b_ok &&
             sinks_ok &&
             alibi_ok &&
@@ -252,6 +259,7 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
                 !direct_sparse_enabled ? "direct_sparse_disabled" :
                 !policy.token_shape_allowed ? "token_shape_not_allowed" :
                 policy.compact_large_decode_top_k ? "direct_sparse_top_k_too_large" :
+                compact_mask_omitted ? "mla_kq_mask_omitted" :
                 !kq_b_ok ? "kq_b_present" :
                 !sinks_ok ? "sinks_present" :
                 !alibi_ok ? "alibi_present" :
@@ -262,7 +270,8 @@ static llama_glm_dsa_sparse_attn_policy llama_glm_dsa_choose_sparse_attn_policy(
     policy.compact_selector_reason =
             compact_flash_disabled ? "disabled" :
             !flash_attn ? "flash_attn_disabled" :
-            !policy.compact_large_decode_top_k ? "small_decode_top_k_or_not_decode" :
+            !policy.decode_shape ? "not_decode" :
+            !policy.compact_large_decode_top_k && !compact_mask_omitted ? "small_decode_top_k" :
             !kq_b_ok ? "kq_b_present" :
             !sinks_ok ? "sinks_present" :
             !alibi_ok ? "alibi_present" :
@@ -309,6 +318,7 @@ static bool llama_glm_dsa_can_skip_mla_kq_mask_for_compact_decode(
             skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled(),
             cparams.flash_attn,
             skippy_glm_dsa_compact_flash_attn_disabled(),
+            false,
             true,
             true,
             hparams.f_max_alibi_bias == 0.0f,
@@ -384,6 +394,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
         bool    enabled,
         bool    flash_attn,
         bool    decode_shape,
+        bool    no_mask,
         bool    kq_b_ok,
         bool    sinks_ok,
         bool    alibi_ok,
@@ -414,7 +425,7 @@ static void skippy_glm_dsa_log_compact_flash_policy(
             sinks_ok ? 1 : 0,
             alibi_ok ? 1 : 0,
             soft_cap_ok ? 1 : 0,
-            use_compact ? 1 : 0,
+            no_mask ? 1 : 0,
             use_compact ? 1 : 0,
             selector_reason);
 }
@@ -3300,6 +3311,7 @@ ggml_tensor * llm_graph_context::build_attn(
             skippy_glm_dsa_unproven_large_direct_sparse_prefill_enabled(),
             cparams.flash_attn,
             skippy_glm_dsa_compact_flash_attn_disabled(),
+            kq_mask == nullptr,
             direct_sparse_kq_b_ok,
             direct_sparse_sinks_ok,
             direct_sparse_alibi_ok,
@@ -3339,6 +3351,7 @@ ggml_tensor * llm_graph_context::build_attn(
             sparse_policy.compact_candidate,
             sparse_policy.flash_attn,
             sparse_policy.decode_shape,
+            kq_mask == nullptr,
             sparse_policy.kq_b_ok,
             sparse_policy.sinks_ok,
             sparse_policy.alibi_ok,
-- 
2.53.0

