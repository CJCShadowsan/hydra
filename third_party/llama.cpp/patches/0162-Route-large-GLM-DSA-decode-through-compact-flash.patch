From 0535ab2d499822922c5dc63d3d84c41b77e0ccef Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 01:16:51 +1000
Subject: [PATCH] Route large GLM DSA decode through compact flash

---
 src/llama-graph.cpp | 191 +++++++++++++++++++++++++++++++++++++++++++-
 src/llama-graph.h   |   9 +++
 2 files changed, 199 insertions(+), 1 deletion(-)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 7882711fe..6140f5dc3 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -30,12 +30,26 @@ static bool skippy_env_enabled(const char * name) {
     return value != nullptr && strcmp(value, "0") != 0 && strcmp(value, "false") != 0 && strcmp(value, "FALSE") != 0;
 }
 
+static bool skippy_env_disabled(const char * name) {
+    const char * value = getenv(name);
+    return value != nullptr && (strcmp(value, "0") == 0 || strcmp(value, "false") == 0 || strcmp(value, "FALSE") == 0);
+}
+
 static bool skippy_glm_dsa_fused_sparse_mask_enabled() {
     return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_FUSED_SPARSE_MASK");
 }
 
 static bool skippy_glm_dsa_direct_sparse_attn_enabled() {
-    return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_ATTN");
+    if (skippy_env_disabled("SKIPPY_GLM_DSA_ENABLE_DIRECT_SPARSE_ATTN") ||
+        skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_DIRECT_SPARSE_ATTN")) {
+        return false;
+    }
+
+    return true;
+}
+
+static bool skippy_glm_dsa_compact_flash_attn_disabled() {
+    return skippy_env_enabled("SKIPPY_GLM_DSA_DISABLE_COMPACT_FLASH_ATTN");
 }
 
 static bool skippy_glm_dsa_direct_sparse_prefill_enabled() {
@@ -66,6 +80,11 @@ static bool skippy_glm_dsa_direct_sparse_decision_log_enabled() {
     return skippy_env_enabled("SKIPPY_GLM_DSA_LOG_DIRECT_SPARSE_DECISIONS");
 }
 
+static bool skippy_glm_dsa_compact_flash_policy_log_enabled() {
+    return skippy_env_enabled("SKIPPY_GLM_DSA_LOG_COMPACT_FLASH_POLICY") ||
+           skippy_glm_dsa_direct_sparse_decision_log_enabled();
+}
+
 static bool skippy_glm_dsa_moe_weighted_sum_enabled() {
     return skippy_env_enabled("SKIPPY_GLM_DSA_ENABLE_MOE_WEIGHTED_SUM");
 }
@@ -132,6 +151,51 @@ static void skippy_glm_dsa_log_direct_sparse_decision(
             use_direct ? 1 : 0);
 }
 
+static void skippy_glm_dsa_log_compact_flash_policy(
+        int     layer,
+        int64_t ubatch_tokens,
+        int64_t visible_kv,
+        int64_t top_k,
+        bool    disabled,
+        bool    large_decode_top_k,
+        bool    enabled,
+        bool    flash_attn,
+        bool    decode_shape,
+        bool    kq_b_ok,
+        bool    sinks_ok,
+        bool    alibi_ok,
+        bool    soft_cap_ok,
+        bool    use_compact,
+        const char * selector_reason) {
+    if (!skippy_glm_dsa_compact_flash_policy_log_enabled()) {
+        return;
+    }
+
+    LLAMA_LOG_INFO(
+            "skippy: glm_dsa_compact_flash_policy layer=%d ubatch_tokens=%lld visible_kv=%lld top_k=%lld kv_topk_ratio=%lld min_kv_topk_ratio=%lld forced=%d disabled=%d large_decode_top_k=%d ratio_ok=%d enabled=%d flash_attn=%d phase=%s decode_shape=%d kq_b_ok=%d sinks_ok=%d alibi_ok=%d soft_cap_ok=%d no_mask=%d use_compact=%d selector_reason=%s\n",
+            layer,
+            (long long) ubatch_tokens,
+            (long long) visible_kv,
+            (long long) top_k,
+            top_k > 0 ? (long long) (visible_kv/top_k) : 0LL,
+            2LL,
+            0,
+            disabled ? 1 : 0,
+            large_decode_top_k ? 1 : 0,
+            0,
+            enabled ? 1 : 0,
+            flash_attn ? 1 : 0,
+            decode_shape ? "decode" : "other",
+            decode_shape ? 1 : 0,
+            kq_b_ok ? 1 : 0,
+            sinks_ok ? 1 : 0,
+            alibi_ok ? 1 : 0,
+            soft_cap_ok ? 1 : 0,
+            use_compact ? 1 : 0,
+            use_compact ? 1 : 0,
+            selector_reason);
+}
+
 void skippy_graph_set_filter(const skippy_graph_filter & filter) {
     g_skippy_graph_filter = filter;
 }
@@ -2558,6 +2622,74 @@ ggml_tensor * llm_graph_context::build_attn_mha_dsa_sparse(
     return cur;
 }
 
+ggml_tensor * llm_graph_context::build_attn_mha_dsa_compact_flash(
+         ggml_tensor * q,
+         ggml_tensor * k,
+         ggml_tensor * v,
+         ggml_tensor * top_k,
+         ggml_tensor * v_mla,
+               float   kq_scale,
+                 int   il) const {
+    const bool v_trans = v->nb[1] > v->nb[2];
+
+    const auto n_stream = k->ne[3];
+
+    q = ggml_view_4d(ctx0, q, q->ne[0], q->ne[1], q->ne[2]/n_stream, n_stream, q->nb[1], q->nb[2], q->nb[3]/n_stream, 0);
+
+    q = ggml_permute(ctx0, q, 0, 2, 1, 3);
+    k = ggml_permute(ctx0, k, 0, 2, 1, 3);
+    v = ggml_permute(ctx0, v, 0, 2, 1, 3);
+
+    if (v_trans) {
+        v = ggml_transpose(ctx0, v);
+    }
+
+    GGML_ASSERT(top_k->ne[1] == k->ne[2]);
+    GGML_ASSERT(top_k->ne[2] == k->ne[3]);
+    GGML_ASSERT(top_k->ne[1] == v->ne[2]);
+    GGML_ASSERT(top_k->ne[2] == v->ne[3]);
+
+    ggml_tensor * k_top_k = ggml_get_rows(ctx0, k, top_k);
+    cb(k_top_k, "dsa_compact_k_topk_rows", il);
+    if (k_top_k->type == GGML_TYPE_F32) {
+        k_top_k = ggml_cast(ctx0, k_top_k, GGML_TYPE_F16);
+        cb(k_top_k, "dsa_compact_k_topk_rows_f16", il);
+    }
+
+    ggml_tensor * v_top_k = ggml_get_rows(ctx0, v, top_k);
+    cb(v_top_k, "dsa_compact_v_topk_rows", il);
+    if (v_top_k->type == GGML_TYPE_F32) {
+        v_top_k = ggml_cast(ctx0, v_top_k, GGML_TYPE_F16);
+        cb(v_top_k, "dsa_compact_v_topk_rows_f16", il);
+    }
+
+    ggml_tensor * cur = ggml_flash_attn_ext(
+            ctx0,
+            q,
+            k_top_k,
+            v_top_k,
+            nullptr,
+            kq_scale,
+            hparams.f_max_alibi_bias,
+            hparams.attn_soft_cap ? hparams.f_attn_logit_softcapping : 0.0f);
+    cb(cur, LLAMA_TENSOR_NAME_FATTN, il);
+    ggml_flash_attn_ext_set_prec(cur, GGML_PREC_F32);
+
+    if (v_mla) {
+        cur = ggml_permute(ctx0, cur, 0, 2, 1, 3);
+        cur = ggml_mul_mat(ctx0, v_mla, cur);
+        cb(cur, "fattn_mla", il);
+        cur = ggml_permute(ctx0, cur, 0, 2, 1, 3);
+        cur = ggml_cont(ctx0, cur);
+    }
+
+    cur = ggml_reshape_2d(ctx0, cur, cur->ne[0]*cur->ne[1], cur->ne[2]*cur->ne[3]);
+
+    ggml_build_forward_expand(gf, cur);
+
+    return cur;
+}
+
 llm_graph_input_attn_no_cache * llm_graph_context::build_attn_inp_no_cache() const {
     auto inp = std::make_unique<llm_graph_input_attn_no_cache>(hparams, cparams);
 
@@ -2877,6 +3009,8 @@ ggml_tensor * llm_graph_context::build_attn(
 
     const int64_t n_direct_sparse_stream = cparams.kv_unified ? 1 : ubatch.n_seqs_unq;
     const int64_t n_direct_sparse_batch = top_k_3d->ne[1];
+    const int64_t n_sparse_kv = kq_mask_rows->ne[1];
+    const int64_t n_sparse_top_k = top_k_3d->ne[0];
     const int64_t dense_sparse_mask_bytes = (int64_t) ggml_nbytes(kq_mask_rows);
     const int64_t dense_sparse_mask_limit = skippy_glm_dsa_dense_sparse_mask_max_bytes();
     const bool direct_sparse_prefill_enabled = skippy_glm_dsa_direct_sparse_prefill_enabled();
@@ -2901,8 +3035,31 @@ ggml_tensor * llm_graph_context::build_attn(
     const bool direct_sparse_sinks_ok = sinks == nullptr;
     const bool direct_sparse_alibi_ok = hparams.f_max_alibi_bias == 0.0f;
     const bool direct_sparse_soft_cap_ok = !hparams.attn_soft_cap;
+    const bool compact_flash_disabled = skippy_glm_dsa_compact_flash_attn_disabled();
+    const bool compact_flash_large_decode_top_k =
+            direct_sparse_decode_shape &&
+            n_sparse_top_k > 1024;
+    const bool use_compact_flash_attn =
+            !compact_flash_disabled &&
+            cparams.flash_attn &&
+            compact_flash_large_decode_top_k &&
+            direct_sparse_kq_b_ok &&
+            direct_sparse_sinks_ok &&
+            direct_sparse_alibi_ok &&
+            direct_sparse_soft_cap_ok;
+    const char * compact_flash_selector_reason =
+            use_compact_flash_attn ? "decode_compact_large_top_k" :
+            compact_flash_disabled ? "disabled" :
+            !cparams.flash_attn ? "flash_attn_disabled" :
+            !compact_flash_large_decode_top_k ? "small_decode_top_k_or_not_decode" :
+            !direct_sparse_kq_b_ok ? "kq_b_present" :
+            !direct_sparse_sinks_ok ? "sinks_present" :
+            !direct_sparse_alibi_ok ? "alibi_present" :
+            !direct_sparse_soft_cap_ok ? "soft_cap_present" :
+            "unknown";
 
     const bool use_direct_sparse_attn =
+            !use_compact_flash_attn &&
             direct_sparse_enabled &&
             direct_sparse_token_shape_allowed &&
             direct_sparse_kq_b_ok &&
@@ -2930,6 +3087,38 @@ ggml_tensor * llm_graph_context::build_attn(
             direct_sparse_soft_cap_ok,
             use_direct_sparse_attn);
 
+    skippy_glm_dsa_log_compact_flash_policy(
+            il,
+            ubatch.n_tokens,
+            n_sparse_kv,
+            n_sparse_top_k,
+            compact_flash_disabled,
+            compact_flash_large_decode_top_k,
+            !compact_flash_disabled && compact_flash_large_decode_top_k,
+            cparams.flash_attn,
+            direct_sparse_decode_shape,
+            direct_sparse_kq_b_ok,
+            direct_sparse_sinks_ok,
+            direct_sparse_alibi_ok,
+            direct_sparse_soft_cap_ok,
+            use_compact_flash_attn,
+            compact_flash_selector_reason);
+
+    if (use_compact_flash_attn) {
+        ggml_tensor * cur = build_attn_mha_dsa_compact_flash(q, k, v, top_k_3d, v_mla, kq_scale, il);
+        cb(cur, "kqv_out", il);
+
+        if (wo) {
+            cur = build_lora_mm(wo, cur, wo_s);
+        }
+
+        if (wo_b) {
+            cur = ggml_add(ctx0, cur, wo_b);
+        }
+
+        return cur;
+    }
+
     if (use_direct_sparse_attn) {
         ggml_tensor * cur = build_attn_mha_dsa_sparse(q, k, v, kq_mask_rows, top_k_3d, v_mla, kq_scale, il);
         cb(cur, "kqv_out", il);
diff --git a/src/llama-graph.h b/src/llama-graph.h
index a80df589b..e9280a066 100644
--- a/src/llama-graph.h
+++ b/src/llama-graph.h
@@ -1094,6 +1094,15 @@ struct llm_graph_context {
                   float   kq_scale,
                     int   il) const;
 
+    ggml_tensor * build_attn_mha_dsa_compact_flash(
+            ggml_tensor * q,
+            ggml_tensor * k,
+            ggml_tensor * v,
+            ggml_tensor * top_k,
+            ggml_tensor * v_mla,
+                  float   kq_scale,
+                    int   il) const;
+
     llm_graph_input_attn_no_cache * build_attn_inp_no_cache() const;
 
     ggml_tensor * build_attn(
-- 
