From 233e957bbe9c6a6f12efb51639625aa686ea4abf Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Fri, 3 Jul 2026 11:54:25 +1000
Subject: [PATCH] Fix GLM DSA sparse attention output layout

---
 ggml/src/ggml.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/ggml/src/ggml.c b/ggml/src/ggml.c
index 19ad669ad..fd25ec902 100644
--- a/ggml/src/ggml.c
+++ b/ggml/src/ggml.c
@@ -6398,7 +6398,7 @@ struct ggml_tensor * ggml_dsa_sparse_attn(
     GGML_ASSERT(q->ne[2] % k->ne[2] == 0);
     GGML_ASSERT(q->ne[2] % v->ne[2] == 0);
 
-    int64_t ne[4] = { v->ne[0], q->ne[2], q->ne[1], q->ne[3] };
+    int64_t ne[4] = { v->ne[0], q->ne[1], q->ne[2], q->ne[3] };
     struct ggml_tensor * result = ggml_new_tensor(ctx, GGML_TYPE_F32, 4, ne);
 
     result->op     = GGML_OP_DSA_SPARSE_ATTN;
-- 
