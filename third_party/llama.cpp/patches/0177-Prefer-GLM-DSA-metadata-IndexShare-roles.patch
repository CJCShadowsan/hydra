From bd7f93ff9dc0047d82e87f671ec1bece2c5cacb8 Mon Sep 17 00:00:00 2001
From: Mesh-LLM CI <ci@mesh-llm.local>
Date: Thu, 2 Jul 2026 07:04:48 +1000
Subject: [PATCH] Prefer GLM DSA metadata IndexShare roles

---
 src/models/glm-dsa.cpp | 35 +++++++++++++++++++++++------------
 src/skippy.cpp         | 12 ++++++------
 2 files changed, 29 insertions(+), 18 deletions(-)

diff --git a/src/models/glm-dsa.cpp b/src/models/glm-dsa.cpp
index e76837089..dcd7f00dc 100644
--- a/src/models/glm-dsa.cpp
+++ b/src/models/glm-dsa.cpp
@@ -156,6 +156,8 @@ static void llama_glm_dsa_validate_indexer_type_frequency_consistency(const llam
         return;
     }
 
+    int conflict_count = 0;
+    int first_conflict = -1;
     for (uint32_t il = 0; il < hparams.n_layer(); ++il) {
         const bool role_full = hparams.indexer_types[il] == 1;
         const bool freq_full = llama_glm_dsa_frequency_layer_is_full(
@@ -163,11 +165,20 @@ static void llama_glm_dsa_validate_indexer_type_frequency_consistency(const llam
                 hparams.indexer_skip_top_k_offset,
                 hparams.indexer_top_k_freq);
         if (role_full != freq_full) {
-            std::ostringstream message;
-            message << "GLM_DSA attention.indexer.types conflicts with top_k_frequency at layer " << il;
-            throw std::runtime_error(message.str());
+            ++conflict_count;
+            if (first_conflict < 0) {
+                first_conflict = (int) il;
+            }
         }
     }
+
+    if (conflict_count > 0) {
+        LLAMA_LOG_WARN(
+                "%s: GLM_DSA attention.indexer.types differs from top_k_frequency at %d layer(s), first=%d; using explicit indexer.types metadata\n",
+                __func__,
+                conflict_count,
+                first_conflict);
+    }
 }
 
 static bool llama_glm_dsa_metadata_layer_is_full(const llama_hparams & hparams, int il, bool * matched) {
@@ -243,6 +254,15 @@ static void llama_glm_dsa_validate_nextn_indexer_contract(int il, const llama_hp
 static bool llama_glm_dsa_layer_uses_indexer(int il, const llama_hparams & hparams, const llama_layer & layer) {
     const bool has_indexer = llama_glm_dsa_layer_has_indexer(layer);
 
+    bool metadata_matched = false;
+    const bool metadata_full = llama_glm_dsa_metadata_layer_is_full(hparams, il, &metadata_matched);
+    if (metadata_matched) {
+        if (metadata_full && !has_indexer) {
+            throw std::runtime_error("GLM_DSA IndexShare metadata selects a Full layer without indexer tensors");
+        }
+        return metadata_full;
+    }
+
     bool pattern_matched = false;
     const bool pattern_full = llama_glm_dsa_indexshare_pattern_layer_is_full(
             getenv("LLAMA_GLM_DSA_INDEXSHARE_PATTERN"),
@@ -255,15 +275,6 @@ static bool llama_glm_dsa_layer_uses_indexer(int il, const llama_hparams & hpara
         return pattern_full;
     }
 
-    bool metadata_matched = false;
-    const bool metadata_full = llama_glm_dsa_metadata_layer_is_full(hparams, il, &metadata_matched);
-    if (metadata_matched) {
-        if (metadata_full && !has_indexer) {
-            throw std::runtime_error("GLM_DSA IndexShare metadata selects a Full layer without indexer tensors");
-        }
-        return metadata_full;
-    }
-
     if (!has_indexer) {
         return false;
     }
diff --git a/src/skippy.cpp b/src/skippy.cpp
index 8301a25fd..3e0af5ba7 100644
--- a/src/skippy.cpp
+++ b/src/skippy.cpp
@@ -1219,6 +1219,12 @@ static bool skippy_glm_dsa_metadata_layer_uses_indexer(const llama_hparams & hpa
 }
 
 static bool skippy_glm_dsa_layer_uses_indexer(const llama_hparams & hparams, int32_t layer_index, const llama_layer & layer) {
+    bool metadata_matched = false;
+    const bool metadata_full = skippy_glm_dsa_metadata_layer_uses_indexer(hparams, layer_index, &metadata_matched);
+    if (metadata_matched) {
+        return metadata_full;
+    }
+
     bool pattern_matched = false;
     const bool pattern_full = skippy_glm_dsa_indexshare_pattern_layer_is_full(
             getenv("LLAMA_GLM_DSA_INDEXSHARE_PATTERN"),
@@ -1228,12 +1234,6 @@ static bool skippy_glm_dsa_layer_uses_indexer(const llama_hparams & hparams, int
         return pattern_full;
     }
 
-    bool metadata_matched = false;
-    const bool metadata_full = skippy_glm_dsa_metadata_layer_uses_indexer(hparams, layer_index, &metadata_matched);
-    if (metadata_matched) {
-        return metadata_full;
-    }
-
     if (!skippy_glm_dsa_layer_has_indexer(layer)) {
         return false;
     }
-- 
