<div class="cta-terminal" aria-label="Hydra install and serve commands">
  <div class="cta-terminal-bar">
    <div class="cta-window-dots" aria-hidden="true">
      <span class="red"></span>
      <span class="yellow"></span>
      <span class="green"></span>
    </div>
    <div class="cta-terminal-tabs" role="tablist" aria-label="Install methods">
      <button class="active" type="button" role="tab" aria-selected="true" data-install-method="cargo" data-install-copy="cargo install --git https://github.com/CJCShadowsan/hydra.git --package mesh-llm --bin hydra">cargo</button>
      <button type="button" role="tab" aria-selected="false" hidden aria-hidden="true" data-install-unavailable="true" data-install-method="release" data-install-copy="Hydra packaged releases are not published yet">release</button>
    </div>
    <div class="cta-terminal-meta">~ &middot; zsh &middot; hydra</div>
    <button class="cta-copy" type="button" data-copy-text="cargo install --git https://github.com/CJCShadowsan/hydra.git --package mesh-llm --bin hydra" aria-label="Copy install command">COPY</button>
  </div>

  <div class="cta-terminal-body">
    <div class="cta-terminal-block">
      <p class="comment"># Install from source until Hydra release archives are published</p>
      <p class="cta-install-command" data-install-command-display aria-live="polite"><span class="prompt">$</span> <span class="cmd">cargo</span> <span class="cmd">install</span> <span class="flag">--git</span> <span class="value">https://github.com/CJCShadowsan/hydra.git</span> <span class="flag">--package</span> <span class="value">mesh-llm</span> <span class="flag">--bin</span> <span class="value">hydra</span></p>
      <template data-install-template="cargo"><span class="prompt">$</span> <span class="cmd">cargo</span> <span class="cmd">install</span> <span class="flag">--git</span> <span class="value">https://github.com/CJCShadowsan/hydra.git</span> <span class="flag">--package</span> <span class="value">mesh-llm</span> <span class="flag">--bin</span> <span class="value">hydra</span></template>
      <template data-install-template="brew"><span class="prompt">$</span> <span class="cmd">brew</span> <span class="cmd">install</span> <span class="value">mesh-llm/tap/mesh-llm</span></template>
    </div>

    <div class="cta-terminal-block">
      <p class="comment"># Finish setup</p>
      <p><span class="prompt">$</span> <span class="cmd">hydra</span> <span class="cmd">setup</span></p>
    </div>

    <div class="cta-terminal-block">
      <p class="comment"># Serve a private Hydra node</p>
      <p><span class="prompt">$</span> <span class="cmd">hydra</span> <span class="cmd">serve</span> <span class="flag">--model</span> <span class="value">Qwen3-8B-Q4_K_M</span></p>
      <p class="status"><span class="caret">&rsaquo;</span> hydra discovery namespace active <span class="ok">[ok]</span></p>
      <p class="status"><span class="caret">&rsaquo;</span> private invite token ready <span class="ok">[ok]</span></p>
      <p class="status"><span class="caret">&rsaquo;</span> proxy listening on <span class="value">localhost:3131</span> <span class="ok">[ok]</span></p>
    </div>

    <div class="cta-terminal-block">
      <p class="comment"># Or serve an 8GB VRAM-friendly catalog model</p>
      <p><span class="prompt">$</span> <span class="cmd">hydra</span> <span class="cmd">serve</span> <span class="flag">--model</span> <span class="value">gemma-4-26B-A4B-it-UD-Q4_K_M</span></p>
    </div>

    <div class="cta-terminal-block">
      <p class="comment"># Point any OpenAI client at Hydra</p>
      <p><span class="prompt">$</span> <span class="cmd">export</span> <span class="value">OPENAI_BASE_URL=http://localhost:3131/v1</span></p>
    </div>
  </div>

  <div class="cta-terminal-footer">
    <span class="live-dot" aria-hidden="true"></span>
    <span>stream</span>
    <strong><span class="caret">&rsaquo;</span> GLM-4.5-Air-Q4_K_M</strong>
    <span>42 t/s &middot; ttft 187 ms</span>
    <span>pipeline-split &middot; 3 peers</span>
  </div>
</div>
